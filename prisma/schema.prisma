generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ROOT
  ADMIN
  EDITOR
  VIEWER
}

enum MediaAssetType {
  image
  video
}

enum DisplayMode {
  AUTOPLAY
  PINNED
  MANUAL
}

enum DisplayCommand {
  CONFIG_SYNC
  NEXT
  PREVIOUS
  RELOAD
  RESYNC
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(EDITOR)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model MembershipSubmission {
  id             String   @id @default(cuid())
  legalName      String
  commercialName String?
  email          String
  phone          String
  nifCif         String
  type           String
  notes          String?
  dniFileUrl     String?
  dniFileKey     String?
  modelFileUrl   String?
  modelFileKey   String?
  certificateUrl String?
  certificateKey String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  topic     String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model ProfessionalSubmission {
  id           String   @id @default(cuid())
  businessName String
  sector       String
  email        String
  phone        String
  status       String   @default("pending")
  createdAt    DateTime @default(now())
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  status    String   @default("active")
  createdAt DateTime @default(now())
}

model MediaAsset {
  id               String            @id @default(cuid())
  name             String
  type             MediaAssetType
  url              String
  key              String            @unique
  createdAt        DateTime          @default(now())
  playlistItems    PlaylistAsset[]
  pinnedDisplays   DisplayDevice[]   @relation("PinnedAsset")
}

model Playlist {
  id        String          @id @default(cuid())
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now()) @updatedAt
  items     PlaylistAsset[]
  displays  DisplayDevice[]
}

model PlaylistAsset {
  id          String     @id @default(cuid())
  playlistId  String
  assetId     String
  order       Int
  durationSec Int        @default(10)
  createdAt   DateTime   @default(now())
  playlist    Playlist   @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  asset       MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([playlistId, order])
  @@index([playlistId, order])
  @@index([assetId])
}

model DisplayDevice {
  id                String         @id @default(cuid())
  name              String
  pairingCode       String?        @unique
  pairingExpiresAt  DateTime?
  deviceToken       String?        @unique
  isPaired          Boolean        @default(false)
  lastPing          DateTime?
  mode              DisplayMode    @default(AUTOPLAY)
  playlistId        String?
  pinnedAssetId     String?
  manualIndex       Int            @default(0)
  configVersion     Int            @default(1)
  lastCommand       DisplayCommand @default(CONFIG_SYNC)
  lastCommandAt     DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @default(now()) @updatedAt
  playlist          Playlist?      @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  pinnedAsset       MediaAsset?    @relation("PinnedAsset", fields: [pinnedAssetId], references: [id], onDelete: SetNull)

  @@index([isPaired, lastPing])
  @@index([playlistId])
  @@index([pinnedAssetId])
}

model Slide {
  id          String   @id @default(cuid())
  type        String
  url         String
  key         String
  durationSec Int      @default(10)
  order       Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}
