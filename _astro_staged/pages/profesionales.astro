---
import proImage from "../assets/images/supermercado-interior.webp";
import ProfessionalForm from "../components/forms/ProfessionalForm";
import Icon from "../components/ui/Icon";
import Layout from "../layouts/Layout.astro";

const title = "Proveedor HORECA Tenerife | Mayorista Alimentación y Bebidas";
const description = "Terencio Profesionales: Tu proveedor integral para hostelería en Tenerife. Alimentación, bebidas, limpieza y menaje. Precios netos competitivos.";
---

<Layout title={title} description={description} image={proImage.src}>
  
  <!-- Hero Section: Split Layout for High Conversion -->
  <section class="relative bg-slate-900 min-h-screen flex items-center pt-20 pb-12 lg:pt-24 lg:pb-16 overflow-hidden">
      <!-- Dynamic Background -->
      <div class="absolute inset-0 z-0">
          <img src={proImage.src} alt="Almacén Terencio" class="w-full h-full object-cover opacity-10 blur-sm scale-105" />
          <div class="absolute inset-0 bg-gradient-to-r from-slate-900 via-slate-900/95 to-slate-900/40"></div>
      </div>

      <div class="container mx-auto px-4 relative z-10">
          <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">
              
              <!-- Left Column: Value Prop -->
              <div class="lg:col-span-7 space-y-6">
                  <div class="inline-flex items-center gap-2 bg-green-500/10 border border-green-500/30 text-green-400 px-4 py-1.5 rounded-full text-sm font-bold uppercase tracking-wider">
                      <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                      Zona B2B Exclusiva
                  </div>
                  
                  <h1 class="text-4xl md:text-5xl lg:text-5xl font-extrabold text-white leading-tight">
                      El Partner Integral para tu <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-600">Negocio HORECA</span>
                  </h1>
                  
                  <p class="text-base md:text-lg text-slate-300 leading-relaxed max-w-2xl">
                      Centraliza tus compras. Olvídate de gestionar 10 proveedores. <strong>Alimentación, Bebidas, Limpieza y Menaje</strong> en un solo pedido, una sola factura y con precios netos desde la primera unidad.
                  </p>

                  <div class="flex flex-col sm:flex-row gap-3 pt-4">
                      <div class="flex items-center gap-3 text-white text-sm font-medium bg-white/5 px-4 py-2.5 rounded-xl border border-white/10 backdrop-blur-sm">
                          <Icon name="Package" className="text-green-400 w-5 h-5" /> Muelle de Carga
                      </div>
                      <div class="flex items-center gap-3 text-white text-sm font-medium bg-white/5 px-4 py-2.5 rounded-xl border border-white/10 backdrop-blur-sm">
                          <Icon name="Clock" className="text-green-400 w-5 h-5" /> Servicio 362 días
                      </div>
                      <div class="flex items-center gap-3 text-white text-sm font-medium bg-white/5 px-4 py-2.5 rounded-xl border border-white/10 backdrop-blur-sm">
                          <Icon name="BadgeEuro" className="text-green-400 w-5 h-5" /> Tarifas Netas
                      </div>
                  </div>
                  
                  <div class="pt-8 flex items-center gap-4 text-sm text-slate-400">
                      <div class="flex -space-x-3">
                          <div class="w-10 h-10 rounded-full bg-slate-700 border-2 border-slate-900 flex items-center justify-center text-xs text-white font-bold">GU</div>
                          <div class="w-10 h-10 rounded-full bg-slate-600 border-2 border-slate-900 flex items-center justify-center text-xs text-white font-bold">RE</div>
                          <div class="w-10 h-10 rounded-full bg-slate-500 border-2 border-slate-900 flex items-center justify-center text-xs text-white font-bold">CA</div>
                      </div>
                      <p>Más de 500 negocios en Tenerife confían en nosotros.</p>
                  </div>
              </div>

              <!-- Right Column: Lead Form -->
              <div class="lg:col-span-5 relative">
                  <div class="absolute -inset-1 bg-gradient-to-br from-green-500 to-emerald-700 rounded-3xl opacity-30 blur-lg"></div>
                  <div class="relative bg-white rounded-2xl shadow-2xl p-5 md:p-6 border border-slate-100">
                      <div class="mb-5 text-center">
                          <h3 class="font-bold text-xl text-slate-900">Solicita Tarifas Profesionales</h3>
                          <p class="text-xs text-slate-500 mt-1.5">Acceso a precios mayoristas y condiciones especiales.</p>
                      </div>
                      <ProfessionalForm client:visible />
                      <p class="text-xs text-center text-slate-400 mt-4 border-t border-slate-100 pt-4">
                          🔒 Tus datos son tratados con confidencialidad para uso comercial exclusivo.
                      </p>
                  </div>
              </div>

          </div>
      </div>
  </section>
  <!-- Pain Points / Solutions Grid -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-20">
        <span class="text-green-600 font-bold uppercase tracking-widest text-sm bg-green-50 px-4 py-1 rounded-full">Ventajas Competitivas</span>
        <h2 class="text-4xl font-bold text-slate-900 mt-6 mb-6">¿Por qué cambiar a Terencio?</h2>
        <p class="text-xl text-slate-600 leading-relaxed">
            Sabemos que el margen es la clave de tu negocio. Hemos eliminado intermediarios y costes innecesarios para ofrecerte una operativa eficiente y rentable.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Benefit 1 -->
        <div class="p-8 bg-white rounded-[2rem] shadow-xl shadow-slate-200/50 border border-slate-100 hover:border-green-200 hover:-translate-y-2 transition-all duration-300 group">
            <div class="w-16 h-16 bg-green-50 rounded-2xl flex items-center justify-center text-green-600 mb-6 group-hover:bg-green-600 group-hover:text-white transition-colors duration-300">
                <Icon name="AlarmClockOff" size={32} />
            </div>
            <h3 class="font-bold text-xl mb-3 text-slate-900">Servicio de Urgencia</h3>
            <p class="text-slate-600 leading-relaxed">¿Te quedaste sin hielo o pan un domingo? Abrimos todos los días. Somos tu almacén de seguridad cuando otros fallan.</p>
        </div>
        <!-- Benefit 2 -->
        <div class="p-8 bg-white rounded-[2rem] shadow-xl shadow-slate-200/50 border border-slate-100 hover:border-green-200 hover:-translate-y-2 transition-all duration-300 group">
            <div class="w-16 h-16 bg-blue-50 rounded-2xl flex items-center justify-center text-blue-600 mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300">
                <Icon name="FileText" size={32} />
            </div>
            <h3 class="font-bold text-xl mb-3 text-slate-900">Factura Única</h3>
            <p class="text-slate-600 leading-relaxed">Simplifica tu gestión. Agrupamos todas tus compras (frescos, secos, limpieza) en una sola factura mensual detallada.</p>
        </div>
        <!-- Benefit 3 -->
        <div class="p-8 bg-white rounded-[2rem] shadow-xl shadow-slate-200/50 border border-slate-100 hover:border-green-200 hover:-translate-y-2 transition-all duration-300 group">
            <div class="w-16 h-16 bg-orange-50 rounded-2xl flex items-center justify-center text-orange-600 mb-6 group-hover:bg-orange-600 group-hover:text-white transition-colors duration-300">
                <Icon name="Package" size={32} />
            </div>
            <h3 class="font-bold text-xl mb-3 text-slate-900">Carga Fácil</h3>
            <p class="text-slate-600 leading-relaxed">Disponemos de muelle de carga con acceso directo para facilitar tus compras. Tu pedido listo sin esperas.</p>
        </div>
        <!-- Benefit 4 -->
        <div class="p-8 bg-white rounded-[2rem] shadow-xl shadow-slate-200/50 border border-slate-100 hover:border-green-200 hover:-translate-y-2 transition-all duration-300 group">
            <div class="w-16 h-16 bg-purple-50 rounded-2xl flex items-center justify-center text-purple-600 mb-6 group-hover:bg-purple-600 group-hover:text-white transition-colors duration-300">
                <Icon name="Percent" size={32} />
            </div>
            <h3 class="font-bold text-xl mb-3 text-slate-900">Precios Netos</h3>
            <p class="text-slate-600 leading-relaxed">Sin rapels complicados ni descuentos fantasma. Precio final competitivo desde el primer euro para cuidar tu escandallo.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Categories Carousel/Grid -->
  <section class="py-20 bg-slate-50 border-y border-slate-200">
      <div class="container mx-auto px-4">
          <div class="flex flex-col md:flex-row justify-between items-end mb-12">
              <div>
                  <h2 class="text-3xl font-bold text-slate-900 mb-2">Todo lo que tu cocina necesita</h2>
                  <p class="text-slate-600">Más de 5.000 referencias en stock permanente.</p>
              </div>
              <a href="#contacto" class="hidden md:inline-flex items-center text-green-700 font-bold hover:gap-2 transition-all mt-4 md:mt-0">
                  Ver catálogo completo <Icon name="ArrowRight" size={20} className="ml-1" />
              </a>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
              {[
                  { name: "Bodega", icon: "Wine", color: "bg-red-100 text-red-700" },
                  { name: "Limpieza", icon: "Sparkles", color: "bg-blue-100 text-blue-700" },
                  { name: "Carnicería", icon: "Beef", color: "bg-orange-100 text-orange-700" },
                  { name: "Congelados", icon: "Snowflake", color: "bg-cyan-100 text-cyan-700" },
                  { name: "Secos", icon: "Package", color: "bg-yellow-100 text-yellow-700" },
                  { name: "Bebidas", icon: "CupSoda", color: "bg-purple-100 text-purple-700" },
              ].map(cat => (
                  <div class="bg-white p-6 rounded-2xl border border-slate-200 text-center hover:shadow-lg transition cursor-default group">
                      <div class={`w-14 h-14 ${cat.color} rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition`}>
                          <Icon name={cat.icon as any} size={24} />
                      </div>
                      <h3 class="font-bold text-slate-900">{cat.name}</h3>
                  </div>
              ))}
          </div>
      </div>
  </section>

  <!-- CTA Footer -->
  <section class="py-24 bg-white text-center">
      <div class="container mx-auto px-4 max-w-4xl">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">¿Hablamos?</h2>
          <p class="text-xl text-slate-600 mb-10">
              Nuestro equipo comercial está listo para visitarte, conocer tu negocio y prepararte una propuesta a medida sin compromiso.
          </p>
          <div class="flex flex-col sm:flex-row justify-center gap-4">
              <a href="#" onclick="document.querySelector('form').scrollIntoView({behavior: 'smooth'})" class="bg-green-700 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-800 transition shadow-xl hover:shadow-2xl hover:-translate-y-1">
                  Solicitar Visita Comercial
              </a>
              <a href="tel:922636026" class="bg-slate-100 text-slate-700 px-8 py-4 rounded-xl font-bold hover:bg-slate-200 transition border border-slate-200">
                  Llamar a Oficinas
              </a>
          </div>
      </div>
  </section>

</Layout>