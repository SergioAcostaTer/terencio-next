---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import terencioLogo from '../../assets/logo.png';
import SuggestedPost from "../../components/blog/SuggestedPost.astro";
import BlogGrid from "../../components/BlogGrid.astro";
import BlogProductCTA from "../../components/BlogProductCTA.astro";
import siteData from '../../data/siteData.json';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// SEO Schema
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "image": [
    new URL(post.data.image ? post.data.image.src : '/logo.png', Astro.url).href
  ],
  "datePublished": post.data.pubDate.toISOString(),
  "dateModified": post.data.pubDate.toISOString(),
  "author": [{
      "@type": "Person",
      "name": post.data.author,
      "url": siteData.url
  }],
  "publisher": {
      "@type": "Organization",
      "name": "Terencio Cash Market",
      "logo": {
        "@type": "ImageObject",
        "url": new URL('/logo.png', Astro.url).href
      }
  },
  "description": post.data.description
};
---

<Layout 
  title={post.data.title} 
  description={post.data.description} 
  ogImage={post.data.image ? post.data.image.src : undefined}
  type="article"
  publishDate={post.data.pubDate.toISOString()}
  author={post.data.author}
>
  <!-- Schema Injection -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />

  <article class="bg-white">
    
    <!-- Hero Header Inmersivo -->
    <header class="relative py-24 md:py-32 bg-gray-900 text-white overflow-hidden">
        <div class="absolute inset-0">
            {post.data.image && (
                <Image 
                    src={post.data.image as ImageMetadata} 
                    alt={post.data.title} 
                    class="w-full h-full object-cover opacity-20 blur-sm scale-105" 
                    width={1200} 
                    height={600} 
                />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/40 to-gray-900/90"></div>
        </div>
        <div class="container mx-auto px-4 relative z-10 text-center max-w-4xl">
            <div class="inline-flex items-center gap-2 bg-green-600/90 backdrop-blur-md px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-8 shadow-lg">
                <span>{post.data.tags ? post.data.tags[0] : 'Blog Terencio'}</span>
            </div>
            <h1 class="text-3xl md:text-5xl lg:text-6xl font-extrabold mb-8 leading-tight text-white drop-shadow-lg">{post.data.title}</h1>
            <div class="flex items-center justify-center gap-6 text-sm md:text-base text-gray-300 font-medium">
                 <div class="flex items-center gap-2">
                    <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-sm font-bold border-2 border-gray-600">
                        <Image 
                            src={terencioLogo}
                            alt="Terencio Cash Market"
                            class="w-[60%] h-[60%]"
                            width={50}
                            height={50}
                        />
                    </div>
                    <span>{post.data.author}</span>
                 </div>
                 <span class="text-gray-600">•</span>
                 <time datetime={post.data.pubDate.toISOString()} class="flex items-center gap-2">
                    <span class="material-icons-outlined text-lg">calendar_today</span>
                    {post.data.pubDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
                 </time>
            </div>
        </div>
    </header>
      
    <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row gap-12 py-12">
          
          <!-- Main Content -->
          <div class="lg:w-3/4 mx-auto max-w-3xl">
              <!-- Featured Image (Clean & Sharp) -->
              {post.data.image && (
                  <div class="rounded-3xl overflow-hidden shadow-2xl mb-12 -mt-24 relative z-20 border-4 border-white">
                      <Image 
                        src={post.data.image as ImageMetadata} 
                        alt={post.data.title} 
                        class="w-full h-auto object-cover" 
                        width={800} 
                        height={450} 
                      />
                  </div>
              )}

              <div class="prose prose-lg prose-green mx-auto focus:outline-none prose-headings:font-bold prose-headings:text-gray-900 prose-p:text-gray-600 prose-p:leading-loose prose-a:text-green-700 hover:prose-a:text-green-800 prose-img:rounded-2xl prose-img:shadow-lg">
                <Content />
              </div>
              
              <SuggestedPost currentSlug={post.slug} tags={post.data.tags} />

              <!-- Share / Tags Footer -->
              <div class="mt-16 pt-8 border-t border-gray-100">
                  <div class="flex flex-wrap gap-2">
                      {post.data.tags && post.data.tags.map(tag => (
                          <span class="bg-gray-100 text-gray-600 px-4 py-2 rounded-full text-sm font-bold hover:bg-green-50 hover:text-green-700 transition cursor-default">#{tag}</span>
                      ))}
                  </div>
              </div>
          </div>
      </div>
    </div>

    <!-- Enhanced "Last Widget" - Full width CTA BIGGER & BETTER -->
    <section class="py-24 bg-gradient-to-b from-white to-gray-50">
        <div class="container mx-auto px-4">
            <div class="bg-white rounded-[3rem] shadow-2xl overflow-hidden border border-gray-100 relative transform hover:scale-[1.01] transition duration-500">
                <!-- Decorative background elements -->
                <div class="absolute top-0 right-0 w-96 h-96 bg-green-50 rounded-full -translate-y-1/2 translate-x-1/3 z-0 opacity-50"></div>
                <div class="absolute bottom-0 left-0 w-64 h-64 bg-blue-50 rounded-full translate-y-1/2 -translate-x-1/3 z-0 opacity-50"></div>
                
                <div class="relative z-10 py-8">
                     <BlogProductCTA tags={post.data.tags} />
                </div>
            </div>
        </div>
    </section>

    <!-- Recommended Articles Section -->
    <section class="py-20 bg-white border-t border-gray-100">
        <div class="container mx-auto px-4">
            <div class="flex items-end justify-between mb-12">
                <div>
                    <span class="text-green-700 font-bold uppercase tracking-widest text-sm mb-2 block">Sigue leyendo</span>
                    <h2 class="text-3xl md:text-4xl font-bold text-gray-900">También te puede interesar</h2>
                </div>
                <a href="/blog" class="hidden md:inline-flex items-center gap-2 text-gray-900 font-bold hover:text-green-700 transition group">
                    Ver todo el blog 
                    <span class="group-hover:translate-x-1 transition-transform">→</span>
                </a>
            </div>
            
            <BlogGrid maxItems={3} excludeSlug={post.slug} />
            
            <div class="mt-12 text-center md:hidden">
                <a href="/blog" class="inline-block bg-gray-100 text-gray-900 px-8 py-3 rounded-xl font-bold hover:bg-gray-200 transition">Ver todo el blog →</a>
            </div>
        </div>
    </section>

  </article>
</Layout>