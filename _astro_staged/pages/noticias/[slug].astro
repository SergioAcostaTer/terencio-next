---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import siteData from '../../data/siteData.json';

export async function getStaticPaths() {

  const posts = await getCollection('noticias');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, description, image, pubDate, author, category } = post.data;
const { Content } = await post.render();

const formattedDate = pubDate.toLocaleDateString('es-ES', { 
    weekday: 'long', 
    year: 'numeric', 
    month: 'long', 
    day: 'numeric' 
});

// Get the full URL for sharing
const currentUrl = Astro.url.href;
---

<Layout 
  title={title} 
  description={description} 
  ogImage={image.src}
  type="article" 
  publishDate={pubDate.toISOString()} 
  author={author}
>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": title,
    "image": [
      new URL(image.src, Astro.url).href
    ],
    "datePublished": pubDate.toISOString(),
    "dateModified": pubDate.toISOString(),
    "author": [{
        "@type": "Person",
        "name": author,
        "url": "https://terencio.es"
    }],
    "publisher": {
        "@type": "Organization",
        "name": "Terencio Cash Market",
        "logo": {
          "@type": "ImageObject",
          "url": "https://terencio.es/logo.png"
        }
    }
  })} />
  
  <article class="bg-white min-h-screen">
    
    <!-- Article Progress Bar -->
    <div class="fixed top-0 left-0 w-full h-1 bg-gray-200 z-50">
        <div class="h-full bg-green-700 w-0" id="reading-progress"></div>
    </div>

    <!-- Header / Hero -->
    <header class="relative bg-gray-900 py-12 md:py-20 lg:py-32">
        <div class="absolute inset-0 overflow-hidden">
            <Image src={image as any} alt={title} class="w-full h-full object-cover opacity-30 blur-sm scale-110" width={1200} height={600} />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/80 to-transparent"></div>
        </div>
        
        <div class="container mx-auto px-4 relative z-10 max-w-4xl text-center">
            <span class="inline-block py-1 px-3 rounded bg-green-700 text-white text-xs md:text-sm font-bold tracking-wider mb-4 md:mb-6 uppercase">
                {category || 'Noticia Corporativa'}
            </span>
            <h1 class="text-2xl md:text-4xl lg:text-5xl xl:text-6xl font-bold text-white mb-4 md:mb-6 leading-tight px-2">
                {title}
            </h1>
            <div class="flex flex-col md:flex-row items-center justify-center gap-2 md:gap-4 text-gray-300 text-sm md:text-base lg:text-lg">
                <span class="font-medium">{author}</span>
                <span class="hidden md:inline">•</span>
                <time datetime={pubDate.toISOString()}>{formattedDate}</time>
            </div>
        </div>
    </header>

    <!-- Content Container -->
    <div class="container mx-auto px-4 max-w-5xl -mt-6 md:-mt-10 relative z-20 pb-12 md:pb-20">
        <!-- Main Image -->
        <div class="rounded-lg md:rounded-xl overflow-hidden shadow-xl md:shadow-2xl mb-8 md:mb-12 bg-gray-200">
             <Image src={image as any} alt={title} class="w-full h-auto max-h-[400px] md:max-h-[600px] object-cover" width={1200} height={600} />
        </div>

        <!-- Mobile Share Buttons (Sticky at bottom on mobile) -->
        <div class="lg:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 shadow-lg z-40 px-4 py-3">
            <div class="flex items-center justify-between max-w-md mx-auto">
                <span class="text-sm font-bold text-gray-700">Compartir:</span>
                <div class="flex gap-2" id="mobile-share-buttons">
                    <!-- Native Share (if available) -->
                    <button 
                        class="share-native w-10 h-10 rounded-full bg-gray-700 text-white flex items-center justify-center hover:bg-gray-800 transition"
                        aria-label="Compartir"
                        title="Compartir">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                        </svg>
                    </button>
                    <!-- Facebook -->
                    <button 
                        class="share-facebook w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center hover:bg-blue-700 transition"
                        aria-label="Compartir en Facebook"
                        title="Facebook">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                    </button>
                    <!-- Twitter/X -->
                    <button 
                        class="share-twitter w-10 h-10 rounded-full bg-black text-white flex items-center justify-center hover:bg-gray-800 transition"
                        aria-label="Compartir en X (Twitter)"
                        title="X (Twitter)">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                        </svg>
                    </button>
                    <!-- WhatsApp -->
                    { (siteData.contact.whatsapp || siteData.contact.whatsappUrl) ? (
                    <button 
                        class="share-whatsapp w-10 h-10 rounded-full bg-green-700 text-white flex items-center justify-center hover:bg-green-800 transition"
                        aria-label="Compartir en WhatsApp"
                        title="WhatsApp">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                        </svg>
                    </button>
                    ) : (
                    <a 
                        href={`tel:${siteData.contact.phoneRaw}`}
                        class="w-10 h-10 rounded-full bg-blue-500 text-white flex items-center justify-center hover:bg-blue-600 transition"
                        aria-label="Llamar a Tienda"
                        title="Llamar a Tienda">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                        </svg>
                    </a>
                    )}
                    <!-- LinkedIn -->
                    <button 
                        class="share-linkedin w-10 h-10 rounded-full bg-blue-700 text-white flex items-center justify-center hover:bg-blue-800 transition"
                        aria-label="Compartir en LinkedIn"
                        title="LinkedIn">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <div class="grid lg:grid-cols-[1fr_280px] gap-8 lg:gap-12">
            <!-- Main Text -->
            <div class="prose prose-base md:prose-lg prose-green max-w-none text-gray-700 leading-relaxed">
                <Content />
            </div>

            <!-- Desktop Side Share/Nav -->
            <aside class="hidden lg:block space-y-8 sticky top-24 h-fit">
                <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
                    <h4 class="font-bold text-gray-900 mb-4 uppercase text-xs tracking-wider">Compartir artículo</h4>
                    <div class="flex flex-col gap-3" id="desktop-share-buttons">
                        <!-- Native Share (if available) -->
                        <button 
                            class="share-native w-full py-2.5 rounded-lg bg-gray-700 text-white flex items-center justify-center gap-2 hover:bg-gray-800 transition font-medium text-sm"
                            aria-label="Compartir">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                            </svg>
                            Compartir
                        </button>
                        <!-- Facebook -->
                        <button 
                            class="share-facebook w-full py-2.5 rounded-lg bg-blue-600 text-white flex items-center justify-center gap-2 hover:bg-blue-700 transition font-medium text-sm"
                            aria-label="Compartir en Facebook">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                            </svg>
                            Facebook
                        </button>
                        <!-- Twitter/X -->
                        <button 
                            class="share-twitter w-full py-2.5 rounded-lg bg-black text-white flex items-center justify-center gap-2 hover:bg-gray-800 transition font-medium text-sm"
                            aria-label="Compartir en X (Twitter)">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                            </svg>
                            X (Twitter)
                        </button>
                        <!-- WhatsApp -->
                        { (siteData.contact.whatsapp || siteData.contact.whatsappUrl) ? (
                        <button 
                            class="share-whatsapp w-full py-2.5 rounded-lg bg-green-700 text-white flex items-center justify-center gap-2 hover:bg-green-800 transition font-medium text-sm"
                            aria-label="Compartir en WhatsApp">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                            </svg>
                            WhatsApp
                        </button>
                        ) : (
                        <a 
                            href={`tel:${siteData.contact.phoneRaw}`}
                            class="w-full py-2.5 rounded-lg bg-blue-500 text-white flex items-center justify-center gap-2 hover:bg-blue-600 transition font-medium text-sm"
                            aria-label="Llamar a Tienda">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                            Llamar
                        </a>
                        )}
                        <!-- LinkedIn -->
                        <button 
                            class="share-linkedin w-full py-2.5 rounded-lg bg-blue-700 text-white flex items-center justify-center gap-2 hover:bg-blue-800 transition font-medium text-sm"
                            aria-label="Compartir en LinkedIn">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                            </svg>
                            LinkedIn
                        </button>
                        <!-- Copy Link -->
                        <button 
                            class="share-copy w-full py-2.5 rounded-lg bg-gray-200 text-gray-800 flex items-center justify-center gap-2 hover:bg-gray-300 transition font-medium text-sm"
                            aria-label="Copiar enlace">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                            </svg>
                            <span class="copy-text">Copiar enlace</span>
                        </button>
                    </div>
                </div>
                
                <div class="border-t pt-6">
                     <h4 class="font-bold text-gray-900 mb-4 uppercase text-xs tracking-wider">Más en {category}</h4>
                     <a href="/noticias" class="text-green-700 text-sm font-bold hover:underline inline-flex items-center gap-1">
                        Ver todas las noticias 
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                     </a>
                </div>
            </aside>
        </div>

        <!-- Add padding at bottom for mobile sticky share bar -->
        <div class="h-20 lg:hidden"></div>
    </div>

    <!-- Read Next -->
    <div class="bg-gray-50 py-12 md:py-16 border-t border-gray-200">
        <div class="container mx-auto px-4 max-w-6xl">
            <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-6 md:mb-8">Sigue leyendo</h3>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                 <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center min-h-[200px]">
                    <p class="text-gray-500 mb-4">Descubre más novedades sobre Terencio</p>
                    <a href="/noticias" class="px-6 py-2 bg-gray-900 text-white rounded font-bold hover:bg-black transition text-sm md:text-base">Ir a portada de Noticias</a>
                 </div>
            </div>
        </div>
    </div>

  </article>

  <script define:vars={{ currentUrl, title, description }}>
    // Reading progress bar
    window.addEventListener('scroll', () => {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        const bar = document.getElementById("reading-progress");
        if(bar) bar.style.width = scrolled + "%";
    });

    // Social Sharing Functionality
    const shareData = {
        title: title,
        text: description,
        url: currentUrl
    };

    // Facebook Share
    document.querySelectorAll('.share-facebook').forEach(btn => {
        btn.addEventListener('click', () => {
            const url = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(currentUrl)}`;
            window.open(url, '_blank', 'width=600,height=400');
        });
    });

    // Twitter/X Share
    document.querySelectorAll('.share-twitter').forEach(btn => {
        btn.addEventListener('click', () => {
            const text = `${title} - ${description}`;
            const url = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(currentUrl)}`;
            window.open(url, '_blank', 'width=600,height=400');
        });
    });

    // WhatsApp Share
    document.querySelectorAll('.share-whatsapp').forEach(btn => {
        btn.addEventListener('click', () => {
            const text = `${title} - ${description}\n${currentUrl}`;
            const url = `https://wa.me/?text=${encodeURIComponent(text)}`;
            window.open(url, '_blank');
        });
    });

    // LinkedIn Share
    document.querySelectorAll('.share-linkedin').forEach(btn => {
        btn.addEventListener('click', () => {
            const url = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(currentUrl)}`;
            window.open(url, '_blank', 'width=600,height=400');
        });
    });

    // Copy Link
    document.querySelectorAll('.share-copy').forEach(btn => {
        btn.addEventListener('click', async () => {
            try {
                await navigator.clipboard.writeText(currentUrl);
                const textSpan = btn.querySelector('.copy-text');
                if (textSpan) {
                    const originalText = textSpan.textContent;
                    textSpan.textContent = '¡Copiado!';
                    setTimeout(() => {
                        textSpan.textContent = originalText;
                    }, 2000);
                }
            } catch (err) {
                console.error('Error al copiar:', err);
            }
        });
    });

    // Native Share API (if available)
    if (navigator.share) {
        document.querySelectorAll('.share-native').forEach(btn => {
            btn.addEventListener('click', async () => {
                try {
                    await navigator.share(shareData);
                } catch (err) {
                    if (err.name !== 'AbortError') {
                        console.error('Error al compartir:', err);
                    }
                }
            });
        });
    } else {
        // Hide native share button if not supported
        document.querySelectorAll('.share-native').forEach(btn => {
            btn.style.display = 'none';
        });
    }
  </script>

</Layout>
