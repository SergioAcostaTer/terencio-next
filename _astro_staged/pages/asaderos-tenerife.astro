---
import carniceriaInterior from "../assets/images/supermercado-interior.webp";
import Button from "../components/ui/Button.astro";
import Icon from "../components/ui/Icon";
import PageHeader from "../components/ui/PageHeader.astro";
import Section from "../components/ui/Section.astro";
import Layout from "../layouts/Layout.astro";
 
// SEO Metadata
const title = "Asaderos en Tenerife: Carne, Leña y Carbón en La Esperanza | Terencio";
const description = "Todo para tu asadero en Tenerife camino al monte. Carne de fiesta fresca, leña, carbón y bebidas. Parada obligatoria subiendo al Teide o Las Raíces.";
const canonical = "https://terencio.es/asaderos-tenerife";
---

<Layout title={title} description={description} canonical={canonical} image={carniceriaInterior.src}>
  
  <PageHeader 
    title='Todo para tu <span class="text-orange-400">Asadero</span>'
    subtitle="¿Subes al monte? Haz tu parada técnica en La Esperanza. Carne fresca, leña, carbón y todo lo que necesitas sin desviarte."
    badge="Parada Obligatoria"
    bgClass="bg-orange-900"
    gradientClass="bg-gradient-to-b from-orange-900/90 via-orange-800/60 to-orange-900/90"
  >
     <div class="flex flex-wrap gap-4 justify-center">
      <Button href="/carniceria-tenerife" variant="white" class="text-orange-800 hover:bg-orange-50 font-bold">
          Ver Carne de Fiesta
      </Button>
      <Button href="https://maps.app.goo.gl/YourGoogleMapsLink" target="_blank" variant="outline" class="border-white text-white hover:bg-white hover:text-orange-900 font-bold">
         <Icon name="MapPin" className="mr-2"/> Cómo Llegar
      </Button>
    </div>
  </PageHeader>

  <Section class="bg-white">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="prose prose-lg text-gray-600">
           <h2 class="text-3xl font-bold text-gray-900 mb-6">¿Vas de asadero a Las Raíces o al Teide?</h2>
           <p class="leading-relaxed">
             Sabemos que un buen asadero empieza con una buena compra. Estamos ubicados estratégicamente en <strong>La Esperanza</strong>, el último punto para comprar a buen precio antes de subir al monte.
           </p>
           <p class="leading-relaxed mt-4">
             Olvídate de cargar el coche desde abajo. En <strong>Terencio Cash Market</strong> tienes parking fácil y todo lo que necesitas en un solo lugar.
           </p>

           <div class="bg-orange-50 border-l-4 border-orange-500 p-6 my-8 rounded-r-xl">
              <h3 class="text-orange-900 font-bold text-lg mb-2 flex items-center gap-2">
                <Icon name="MapPin" /> Ubicación Estratégica
              </h3>
              <p class="text-orange-800 m-0">
                Estamos a solo <strong>5 minutos de la Vía de Ronda</strong> y en plena subida hacia el Parque Nacional del Teide. La parada perfecta para comprar carne para asadero en La Esperanza.
              </p>
           </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div class="bg-gray-100 rounded-2xl p-6 text-center hover:bg-orange-50 transition border border-gray-200">
                <span class="text-5xl mb-3 block">🥩</span>
                <h3 class="font-bold text-gray-900">Carne Fresca</h3>
                <p class="text-sm text-gray-500 mt-2">Costillas, chuletas y carne de fiesta</p>
            </div>
            <div class="bg-gray-100 rounded-2xl p-6 text-center hover:bg-orange-50 transition border border-gray-200">
                <span class="text-5xl mb-3 block">🔥</span>
                <h3 class="font-bold text-gray-900">Leña y Carbón</h3>
                <p class="text-sm text-gray-500 mt-2">Sacos grandes al mejor precio</p>
            </div>
            <div class="bg-gray-100 rounded-2xl p-6 text-center hover:bg-orange-50 transition border border-gray-200">
                <span class="text-5xl mb-3 block">🧊</span>
                <h3 class="font-bold text-gray-900">Hielo y Bebida</h3>
                <p class="text-sm text-gray-500 mt-2">Cerveza fría y refrescos</p>
            </div>
            <div class="bg-gray-100 rounded-2xl p-6 text-center hover:bg-orange-50 transition border border-gray-200">
                <span class="text-5xl mb-3 block">🥖</span>
                <h3 class="font-bold text-gray-900">Pan y Mojo</h3>
                <p class="text-sm text-gray-500 mt-2">El complemento perfecto</p>
            </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- CTA Section -->
  <section class="py-16 bg-slate-900 text-white text-center relative overflow-hidden">
      <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/wood-pattern.png')]"></div>
      <div class="container mx-auto px-4 relative z-10">
          <h2 class="text-3xl md:text-4xl font-bold mb-6">¿Quieres ir sobre seguro?</h2>
          <p class="text-slate-300 max-w-2xl mx-auto mb-8 text-lg">
            Si sois un grupo grande, puedes llamarnos para reservar tu pedido de carne y recogerlo sin esperas.
          </p>
          <Button href="tel:922550067" class="bg-green-700 hover:bg-green-800 text-white font-bold py-4 px-8 text-lg shadow-lg">
             <Icon name="Phone" className="mr-2" /> Llamar para Reservar
          </Button>
      </div>
  </section>

</Layout>
