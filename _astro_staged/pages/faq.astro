---
import PageHeader from "../components/ui/PageHeader.astro";
import Layout from "../layouts/Layout.astro";
import Icon from "../components/ui/Icon";
import faqs from "../data/faqs.json";
import siteData from "../data/siteData.json";

const title = "Preguntas Frecuentes | Terencio La Esperanza, San Cristóbal de La Laguna";
const description = "Resuelve tus dudas sobre Terencio Cash Market: supermercado abierto hoy domingos en Tenerife, venta al por mayor para hostelería, restaurantes y productos de El Hierro.";

// Categorize FAQs (Simulated logic based on keywords, ideally added to JSON)
const categories = {
  general: faqs.filter(f => f.question.toLowerCase().includes('horario') || f.question.toLowerCase().includes('abierto') || f.question.toLowerCase().includes('tarjeta')),
  productos: faqs.filter(f => f.question.toLowerCase().includes('carne') || f.question.toLowerCase().includes('hierro') || f.question.toLowerCase().includes('stock')),
  profesional: faqs.filter(f => f.question.toLowerCase().includes('autónomo') || f.question.toLowerCase().includes('profesional') || f.question.toLowerCase().includes('alta')),
};
---

<Layout title={title} description={description}>
  <PageHeader 
    title="Centro de <span class='text-green-300'>Ayuda</span>" 
    subtitle="Encuentra respuestas rápidas. Estamos aquí para facilitarte la compra."
    badge="Soporte"
    bgClass="bg-slate-900"
  />

  <!-- Search Bar (Visual) -->
  <div class="relative z-20 -mt-8 max-w-2xl mx-auto px-4">
    <div class="bg-white p-2 rounded-2xl shadow-xl flex items-center border border-gray-200">
        <div class="pl-4 text-gray-400">
            <Icon name="Search" size={24} />
        </div>
        <input 
            type="text" 
            id="faq-search" 
            placeholder="¿Qué estás buscando? (ej. Horario domingo, Carne de fiesta...)" 
            class="w-full p-4 text-lg outline-none text-gray-700 rounded-xl"
        />
    </div>
  </div>

  <section class="py-10 md:py-16 bg-gray-50 min-h-screen">
    <div class="container mx-auto px-4 max-w-4xl">
        
        <!-- Category: General -->
        <div class="mb-12 faq-category">
            <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
                <span class="bg-green-100 text-green-700 p-2 rounded-lg"><Icon name="Store" size={24} /></span>
                Información General y Acceso
            </h2>
            <div class="space-y-4">
                {categories.general.map((faq, index) => (
                    <details class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:border-green-300 transition-all duration-300 overflow-hidden" name="faq-group">
                        <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-lg text-gray-800 hover:text-green-800 transition select-none">
                            <span>{faq.question}</span>
                            <span class="transition-transform duration-300 group-open:rotate-180 bg-gray-50 text-gray-400 group-open:bg-green-50 group-open:text-green-700 p-2 rounded-full">
                                <Icon name="ChevronDown" size={20} />
                            </span>
                        </summary>
                        <div class="text-gray-600 px-6 pb-6 leading-relaxed bg-gray-50/50 border-t border-gray-100">
                            <p>{faq.answer}</p>
                        </div>
                    </details>
                ))}
            </div>
        </div>

        <!-- Category: Productos -->
        <div class="mb-12 faq-category">
            <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
                <span class="bg-red-100 text-red-700 p-2 rounded-lg"><Icon name="Beef" size={24} /></span>
                Productos y Frescos
            </h2>
            <div class="space-y-4">
                {categories.productos.map((faq, index) => (
                    <details class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:border-red-300 transition-all duration-300 overflow-hidden" name="faq-group">
                        <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-lg text-gray-800 hover:text-red-800 transition select-none">
                            <span>{faq.question}</span>
                            <span class="transition-transform duration-300 group-open:rotate-180 bg-gray-50 text-gray-400 group-open:bg-red-50 group-open:text-red-700 p-2 rounded-full">
                                <Icon name="ChevronDown" size={20} />
                            </span>
                        </summary>
                        <div class="text-gray-600 px-6 pb-6 leading-relaxed bg-gray-50/50 border-t border-gray-100">
                            <p>{faq.answer}</p>
                        </div>
                    </details>
                ))}
            </div>
        </div>

        <!-- Category: Profesionales -->
        <div class="mb-12 faq-category">
            <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
                <span class="bg-blue-100 text-blue-700 p-2 rounded-lg"><Icon name="Briefcase" size={24} /></span>
                Profesionales y Facturación
            </h2>
            <div class="space-y-4">
                {categories.profesional.map((faq, index) => (
                    <details class="group bg-white rounded-xl border border-gray-200 shadow-sm hover:border-blue-300 transition-all duration-300 overflow-hidden" name="faq-group">
                        <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-lg text-gray-800 hover:text-blue-800 transition select-none">
                            <span>{faq.question}</span>
                            <span class="transition-transform duration-300 group-open:rotate-180 bg-gray-50 text-gray-400 group-open:bg-blue-50 group-open:text-blue-700 p-2 rounded-full">
                                <Icon name="ChevronDown" size={20} />
                            </span>
                        </summary>
                        <div class="text-gray-600 px-6 pb-6 leading-relaxed bg-gray-50/50 border-t border-gray-100">
                            <p>{faq.answer}</p>
                            <div class="mt-4 flex items-center gap-2">
                                <Icon name="MessageCircleQuestionMark" size={20} className="text-blue-600 shrink-0" />
                                <a href="/profesionales" class="text-blue-700 font-bold hover:underline text-sm">Ir a Zona Profesionales →</a>
                            </div>
                        </div>
                    </details>
                ))}
            </div>
        </div>

        <!-- Still have questions CTA -->
        <div class="bg-white rounded-3xl p-8 md:p-12 text-center border border-gray-200 shadow-lg mt-16">
            <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-6 text-yellow-600">
                <Icon name="MessageCircleQuestionMark" size={32} />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-2">¿No encuentras tu respuesta?</h3>
            <p class="text-gray-600 mb-8 max-w-md mx-auto">Nuestro equipo de atención al cliente te responderá en menos de 24 horas.</p>
            <div class="flex flex-wrap justify-center gap-4">
                <a href="/contacto" class="bg-green-700 text-white px-8 py-3 rounded-xl font-bold hover:bg-green-800 transition shadow-lg hover:shadow-xl">
                    Contactar Ahora
                </a>
                { (siteData.contact.whatsapp || siteData.contact.whatsappUrl) ? (
                <a href={siteData.contact.whatsappUrl || `https://wa.me/34${siteData.contact.phoneRaw}`} target="_blank" class="bg-white text-green-700 border border-green-200 px-8 py-3 rounded-xl font-bold hover:bg-green-50 transition">
                    WhatsApp Web
                </a>
                ) : (
                <a href={`tel:${siteData.contact.phoneRaw}`} class="bg-white text-blue-700 border border-blue-200 px-8 py-3 rounded-xl font-bold hover:bg-blue-50 transition flex items-center justify-center gap-2">
                    <Icon name="Phone" size={20} /> Llamar a Tienda
                </a>
                )}
            </div>
        </div>

    </div>
  </section>

  <!-- Simple Client-side Search Script -->
  <script>
    document.addEventListener('astro:page-load', () => {
        const searchInput = document.getElementById('faq-search');
        if(searchInput) {
            searchInput.addEventListener('input', (e) => {
                const term = (e.target as HTMLInputElement).value.toLowerCase();
                const details = document.querySelectorAll('details');
                
                details.forEach(detail => {
                    const question = detail.querySelector('summary span').textContent.toLowerCase();
                    const answer = detail.querySelector('p').textContent.toLowerCase();
                    
                    if(question.includes(term) || answer.includes(term)) {
                        detail.style.display = 'block';
                        // Highlight logic could go here
                    } else {
                        detail.style.display = 'none';
                    }
                });

                // Hide empty categories visual polish
                document.querySelectorAll('.faq-category').forEach(cat => {
                    const visibleDetails = cat.querySelectorAll('details[style="display: block;"], details:not([style*="display: none"])');
                    if(visibleDetails.length === 0 && term !== '') {
                        (cat as HTMLElement).style.display = 'none';
                    } else {
                        (cat as HTMLElement).style.display = 'block';
                    }
                });
            });
        }
    });
  </script>

  <style>
    details > summary {
      list-style: none;
    }
    details > summary::-webkit-details-marker {
      display: none;
    }
  </style>
</Layout>