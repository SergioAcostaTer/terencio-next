---
import historyImage from "../assets/images-unoptimized/henry-acosta-terencio-laguna.jpg";
import aboutImage from "../assets/images-unoptimized/supermercado-interior.jpg";
import teamImage from "../assets/images-unoptimized/visita-estudiantes-bachillerato.jpg";
import Icon from "../components/ui/Icon";
import PageHeader from "../components/ui/PageHeader.astro";
import Section from "../components/ui/Section.astro";
import ContentWidget from "../components/widgets/ContentWidget.astro";
import Layout from "../layouts/Layout.astro";

const title = "Quiénes Somos | Historia de Supermercado Terencio Tenerife";
const description = "Desde nuestros orígenes con los supermercados en El Hierro hasta ser el Cash & Carry al por mayor de referencia en San Cristóbal de La Laguna. Descubre nuestra historia.";
---

<Layout title={title} description={description} image={aboutImage.src}>
  
  <PageHeader 
    title="Nuestra <span class='text-green-300'>Historia</span>" 
    subtitle="Más de 20 años ofreciendo calidad, frescura y el mejor servicio a las familias canarias. De El Hierro a Tenerife."
    badge="Desde 1999"
    backgroundImage={aboutImage.src}
    bgClass="bg-slate-900"
  />

  <!-- Sección: Orígenes y El Hierro (Storytelling) -->
  <Section class="bg-white overflow-hidden">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-2 gap-8 lg:gap-12 items-center">
        
        <div class="order-2 md:order-1 relative">
            <div class="absolute -top-4 -left-4 w-24 h-24 bg-yellow-100 rounded-full z-0 mix-blend-multiply filter blur-xl"></div>
            <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-green-100 rounded-full z-0 mix-blend-multiply filter blur-xl"></div>
            
            <div class="relative z-10 transform hover:rotate-1 transition duration-500">
                <img 
                  src={historyImage.src} 
                  alt="Henry Acosta y el legado de Supermercados Terencio" 
                  class="rounded-2xl shadow-xl w-full h-auto object-cover border-4 border-white"
                />
                <div class="absolute bottom-6 left-6 bg-white/90 backdrop-blur p-4 rounded-xl shadow-lg max-w-xs border border-gray-100">
                    <p class="text-sm font-bold text-gray-800">📷 Henry Acosta</p>
                    <p class="text-xs text-gray-500">Continuando el legado familiar</p>
                </div>
            </div>
        </div>

        <div class="prose prose-lg text-gray-600 order-1 md:order-2">
          <span class="text-yellow-600 font-bold uppercase tracking-widest text-sm bg-yellow-50 px-3 py-1 rounded-full mb-4 inline-block">Raíces Herreñas</span>
          <h2 class="text-4xl font-bold text-gray-900 mb-6 leading-tight">Una tradición que late desde El Hierro</h2>
          <p>
            Muchos nos recuerdan por nuestra amplia red de establecimientos bajo la marca <strong>Supermercados Terencio en El Hierro</strong>. Nuestro origen se encuentra en la Isla del Meridiano, donde aprendimos el valor de la palabra, el trato cercano y el respeto por el producto local.
          </p>
          <p>
            Esa experiencia forjó nuestro ADN. Aprendimos que la clave del éxito no es solo vender, sino conocer lo que vendes. Hoy, aunque nuestra operativa se ha transformado y modernizado en Tenerife, seguimos siendo el <strong>puente principal para los productos de El Hierro</strong>, trayendo semanalmente quesadillas, queso y piña a San Cristóbal de La Laguna.
          </p>
          <blockquote class="border-l-4 border-yellow-500 pl-4 italic text-gray-800 bg-yellow-50/50 py-2 rounded-r-lg">
              "No olvidamos de dónde venimos para saber a dónde vamos. El Hierro siempre será nuestra casa."
          </blockquote>
        </div>

      </div>
    </div>
  </Section>

  <!-- Sección: El Cambio Estratégico -->
  <Section class="bg-gray-50">
      <div class="container mx-auto px-4 max-w-4xl text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">La Evolución hacia el Cash Market</h2>
          <p class="text-lg text-gray-600 leading-relaxed">
              En un mercado cambiante, tomamos una decisión valiente: centralizar nuestra fuerza. Cerramos pequeñas tiendas para abrir un gran centro en la <strong>Carretera de La Esperanza</strong> que cambiara las reglas del juego.
          </p>
      </div>

      <div class="container mx-auto px-4 grid md:grid-cols-3 gap-6 max-w-6xl">
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl transition duration-300">
              <div class="w-12 h-12 bg-green-100 text-green-700 rounded-xl flex items-center justify-center mb-4 text-xl">💡</div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">La Idea</h3>
              <p class="text-gray-600">Crear un espacio donde una familia pudiera comprar con los mismos precios que un restaurante.</p>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl transition duration-300">
              <div class="w-12 h-12 bg-blue-100 text-blue-700 rounded-xl flex items-center justify-center mb-4 text-xl">🚀</div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">El Modelo</h3>
              <p class="text-gray-600">Eliminar barreras. Sin carnet de socio, sin cuotas, sin mínimos de compra absurdos. Puertas abiertas.</p>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl transition duration-300">
              <div class="w-12 h-12 bg-red-100 text-red-700 rounded-xl flex items-center justify-center mb-4 text-xl">🎯</div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">El Resultado</h3>
              <p class="text-gray-600">El Cash & Carry de referencia en el norte de Tenerife para particulares y profesionales HORECA.</p>
          </div>
      </div>
  </Section>

  <!-- Valores / Pilares -->
  <Section class="bg-white">
    <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
                <h2 class="text-3xl font-bold text-gray-900 mb-8">Nuestros Pilares Fundamentales</h2>
                <div class="space-y-6">
                    <div class="flex gap-4">
                        <div class="w-12 h-12 bg-green-50 rounded-full flex items-center justify-center text-green-600 flex-shrink-0 mt-1">
                            <Icon name="MapPin" size={24} />
                        </div>
                        <div>
                            <h4 class="font-bold text-lg text-gray-900">Cercanía Estratégica</h4>
                            <p class="text-gray-600">En la subida a La Esperanza, servimos de nexo entre la zona metropolitana y el norte. Fácil acceso y aparcamiento real.</p>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <div class="w-12 h-12 bg-green-50 rounded-full flex items-center justify-center text-green-600 flex-shrink-0 mt-1">
                            <Icon name="Tractor" size={24} />
                        </div>
                        <div>
                            <h4 class="font-bold text-lg text-gray-900">Producto Km 0</h4>
                            <p class="text-gray-600">Defendemos al sector primario de las islas. Si es canario y es bueno, lo tenemos en nuestros lineales.</p>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <div class="w-12 h-12 bg-green-50 rounded-full flex items-center justify-center text-green-600 flex-shrink-0 mt-1">
                            <Icon name="Users" size={24} />
                        </div>
                        <div>
                            <h4 class="font-bold text-lg text-gray-900">Vocación de Servicio</h4>
                            <p class="text-gray-600">Somos solucionadores. Si un cliente profesional necesita algo un domingo, ahí estamos para resolverlo.</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="relative h-[400px] rounded-2xl overflow-hidden shadow-2xl group">
                <img 
                  src={teamImage.src} 
                  alt="Equipo de Terencio Cash Market" 
                  class="absolute inset-0 w-full h-full object-cover transition duration-700 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
                <div class="absolute bottom-0 left-0 p-8 text-white">
                    <p class="text-2xl font-bold mb-2">El Equipo Humano</p>
                    <p class="text-gray-200">Más de 30 personas trabajando cada día para ti.</p>
                </div>
            </div>
        </div>
    </div>
  </Section>

  <!-- Sección: Evolución (Noticias Corporativas) -->
  <ContentWidget 
    title="Actualidad Corporativa" 
    subtitle="La Evolución de Terencio"
    collection="noticias" 
    category="Corporativo"
    maxItems={3} 
    bgClass="bg-gray-50 border-t border-gray-200"
  />

  <!-- CTA Final -->
  <section class="py-20 bg-slate-900 text-white text-center relative overflow-hidden">
    <!-- Decorative patterns -->
    <div class="absolute top-0 left-0 w-full h-full opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
    
    <div class="container mx-auto px-4 relative z-10 max-w-4xl">
      <h2 class="text-3xl md:text-5xl font-bold mb-8">Ven a conocer la nueva etapa de Terencio</h2>
      <p class="text-xl text-slate-300 mb-10 leading-relaxed">
        Instalaciones renovadas, mayor surtido y la misma pasión de siempre. Te esperamos en La Esperanza.
      </p>
      
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contacto" class="bg-green-700 text-white px-10 py-4 rounded-xl font-bold hover:bg-green-800 transition shadow-lg shadow-green-900/50">
          Ver Ubicación y Contacto
        </a>
        <a href="/" class="bg-white/10 text-white border border-white/20 px-10 py-4 rounded-xl font-bold hover:bg-white/20 transition backdrop-blur-sm">
          Volver al Inicio
        </a>
      </div>
    </div>
  </section>

</Layout>