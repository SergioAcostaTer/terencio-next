---
import LocationSection from "../components/LocationSection.astro";
import LocalBusinessSchema from "../components/SEO/LocalBusinessSchema.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import Section from "../components/ui/Section.astro";
import siteData from "../data/siteData.json";
import Layout from "../layouts/Layout.astro";

// Keywords: horario terencio, supermercado abierto domingo tenerife, hiperdino abierto hoy (somos la alternativa)
const title = "Horario Terencio Cash Market: La Esperanza | Abierto Domingos y Festivos";
const description = "Consulta el horario de Terencio Cash Market en La Esperanza (Tenerife). Abierto de Lunes a Domingo y Festivos. Tu supermercado siempre disponible cuando otros cierran.";
---

<LocalBusinessSchema />
<Layout title={title} description={description}>
  <PageHeader 
    title="Horario de Apertura" 
    subtitle="Tu supermercado de confianza con horario ampliado. Abrimos todos los días del año para tu comodidad."
    badge="Abierto 362 Días"
  />

  <Section class="bg-white">
    <div class="grid md:grid-cols-2 gap-12 items-start max-w-5xl mx-auto">
      
      <!-- Card Horario Principal -->
      <div class="bg-green-50 p-8 md:p-10 rounded-3xl shadow-sm border border-green-100 relative overflow-hidden">
        <!-- Decoración -->
        <div class="absolute top-0 right-0 w-32 h-32 bg-green-100 rounded-full -mr-16 -mt-16 opacity-50"></div>
        
        <div class="flex items-center gap-4 mb-8 relative z-10">
            <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-2xl shadow-sm">⏰</div>
            <h2 class="text-2xl font-bold text-gray-900">Horario Habitual</h2>
        </div>
        
        <div class="space-y-6 text-lg relative z-10">
            <div class="flex justify-between items-center py-4 border-b border-green-200">
                <span class="font-medium text-gray-700 flex items-center gap-2"><span class="material-icons-outlined text-green-700">calendar_today</span> Lunes a Sábado</span>
                <span class="font-black text-brand-primary text-xl">08:00 - 21:00</span>
            </div>
            <div class="flex justify-between items-center py-4 border-b border-green-200">
                <span class="font-medium text-gray-700 flex items-center gap-2"><span class="material-icons-outlined text-green-700">wb_sunny</span> Domingos</span>
                <span class="font-black text-brand-primary text-xl">08:30 - 20:30</span>
            </div>
            <div class="flex justify-between items-center py-4">
                <span class="font-medium text-gray-700 flex items-center gap-2"><span class="material-icons-outlined text-green-700">celebration</span> Festivos</span>
                <span class="font-black text-brand-primary text-xl">08:30 - 20:30*</span>
            </div>
        </div>
        
        <div class="mt-8 bg-white p-5 rounded-2xl text-sm text-gray-600 border border-green-100 flex gap-3 items-start shadow-sm">
            <span class="material-icons-outlined text-yellow-500 mt-0.5">info</span>
            <p><strong>*Excepciones:</strong> Solo cerramos los días de Navidad (25 Dic), Año Nuevo (1 Ene) y Reyes (6 Ene). El resto de festivos abrimos en horario de domingo.</p>
        </div>
      </div>

      <!-- FAQ y Contacto -->
      <div class="space-y-8">
        <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Preguntas Frecuentes</h2>
            
            <div class="space-y-4">
                <div class="border border-gray-200 rounded-2xl p-5 bg-white shadow-sm hover:border-green-300 transition">
                    <h3 class="font-bold text-lg mb-2 flex items-center gap-2 text-gray-900">
                        <span class="text-green-600 material-icons-outlined">help_outline</span> 
                        ¿Abren los domingos?
                    </h3>
                    <p class="text-gray-600">Sí, somos uno de los pocos supermercados en Tenerife norte con horario completo de domingo (hasta las 20:30 de la tarde).</p>
                </div>

                <div class="border border-gray-200 rounded-2xl p-5 bg-white shadow-sm hover:border-green-300 transition">
                    <h3 class="font-bold text-lg mb-2 flex items-center gap-2 text-gray-900">
                        <span class="text-green-600 material-icons-outlined">restaurant</span> 
                        ¿La carnicería cierra antes?
                    </h3>
                    <p class="text-gray-600">No, nuestros mostradores de carnicería y charcutería mantienen el mismo horario que la tienda para que siempre tengas producto fresco.</p>
                </div>
            </div>
        </div>

        <div class="bg-slate-900 text-white p-8 rounded-3xl shadow-xl text-center">
            <h3 class="font-bold text-xl mb-2">¿Dudas sobre un festivo?</h3>
            <p class="text-slate-300 mb-6">Llámanos y te confirmamos al momento si estamos abiertos.</p>
            <a href={`tel:${siteData.contact.phoneRaw}`} class="inline-flex items-center gap-2 bg-white text-slate-900 px-8 py-3 rounded-xl font-bold hover:bg-green-400 transition-colors shadow-lg transform hover:-translate-y-1">
                <span class="material-icons-outlined">call</span> Llamar Ahora
            </a>
        </div>
      </div>

    </div>
  </Section>

  <LocationSection className="bg-gray-50 text-center" />
</Layout>