---
import Button from "../components/ui/Button.astro";
import Icon from "../components/ui/Icon";
import PageHeader from "../components/ui/PageHeader.astro";
import siteData from "../data/siteData.json";
import Layout from "../layouts/Layout.astro";

const title = "Atención al Cliente Terencio | Resolvemos tus dudas";
const description = "Centro de Atención al Cliente de Terencio Cash Market. Accesos rápidos a facturación, devoluciones, contacto comercial y soporte general.";
---

<Layout title={title} description={description}>
  <PageHeader 
    title="Atención al <span class='text-green-300'>Cliente</span>" 
    subtitle="Estamos a tu disposición para garantizar que tu experiencia de compra sea perfecta."
    badge="Servicio Integral"
    bgClass="bg-slate-800"
  />

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            
            <!-- Card 1: Facturación -->
            <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition-all group">
                <div class="w-14 h-14 bg-white rounded-xl shadow-sm flex items-center justify-center text-green-700 mb-6 group-hover:scale-110 transition">
                    <Icon name="FileText" size={28} />
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">Facturación</h3>
                <p class="text-gray-600 mb-6 text-sm leading-relaxed">
                    ¿Necesitas solicitar una factura o corregir datos fiscales? Gestiona tus documentos administrativos.
                </p>
                <a href={`mailto:${siteData.contact.email}?subject=Consulta Facturación`} class="text-green-700 font-bold text-sm flex items-center gap-1 hover:gap-2 transition-all">
                    Contactar Administración <Icon name="ArrowRight" size={16} />
                </a>
            </div>

            <!-- Card 2: Comercial -->
            <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition-all group">
                <div class="w-14 h-14 bg-white rounded-xl shadow-sm flex items-center justify-center text-blue-700 mb-6 group-hover:scale-110 transition">
                    <Icon name="Briefcase" size={28} />
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">Comercial HORECA</h3>
                <p class="text-gray-600 mb-6 text-sm leading-relaxed">
                    Atención exclusiva para bares, restaurantes y grandes cuentas. Altas, tarifas y pedidos.
                </p>
                <a href="/profesionales" class="text-blue-700 font-bold text-sm flex items-center gap-1 hover:gap-2 transition-all">
                    Zona Profesionales <Icon name="ArrowRight" size={16} />
                </a>
            </div>

            <!-- Card 3: Tienda Física -->
            <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition-all group">
                <div class="w-14 h-14 bg-white rounded-xl shadow-sm flex items-center justify-center text-red-700 mb-6 group-hover:scale-110 transition">
                    <Icon name="Store" size={28} />
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">Dudas en Tienda</h3>
                <p class="text-gray-600 mb-6 text-sm leading-relaxed">
                    Consultas sobre devoluciones, stock disponible en el momento u objetos perdidos.
                </p>
                <a href={`tel:${siteData.contact.phoneRaw}`} class="text-red-700 font-bold text-sm flex items-center gap-1 hover:gap-2 transition-all">
                    Llamar a Tienda <Icon name="Phone" size={16} />
                </a>
            </div>

        </div>

        <!-- FAQ CTA Banner -->
        <div class="mt-16 bg-slate-900 rounded-3xl p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-8 shadow-2xl relative overflow-hidden">
            <!-- Deco -->
            <div class="absolute top-0 right-0 w-64 h-64 bg-slate-800 rounded-full translate-x-1/3 -translate-y-1/3 opacity-50"></div>

            <div class="relative z-10 text-white md:w-2/3">
                <h2 class="text-2xl md:text-3xl font-bold mb-3">¿Tienes preguntas rápidas?</h2>
                <p class="text-slate-300 text-lg">Consulta nuestro Centro de Ayuda antes de contactar. Es posible que tu respuesta ya esté allí.</p>
            </div>
            <div class="relative z-10">
                <Button href="/faq" variant="white" class="text-slate-900 hover:bg-gray-100 border-none px-8 py-4 shadow-xl">
                    Ver Preguntas Frecuentes
                </Button>
            </div>
        </div>

    </div>
  </section>
</Layout>