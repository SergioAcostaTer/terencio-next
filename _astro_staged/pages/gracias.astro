---
import Button from "../components/ui/Button.astro";
import siteData from "../data/siteData.json";
import Layout from "../layouts/Layout.astro";

const title = "¡Gracias por contactar! - Terencio Cash Market";
const description = "Hemos recibido tu mensaje correctamente. Te contestaremos lo antes posible.";
---

<Layout title={title} description={description} canonical={`${siteData.url}/gracias`} noindex={true}>
  <div class="min-h-[70vh] flex items-center justify-center bg-gray-50 py-20">
    <div class="container mx-auto px-4 max-w-2xl text-center">
       
       <div class="bg-white rounded-3xl p-10 md:p-16 shadow-xl border border-gray-100">
          <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-8 animate-bounce">
             <span class="material-icons-outlined text-6xl text-green-600">check_circle</span>
          </div>

          <h1 class="text-3xl md:text-5xl font-bold text-gray-900 mb-6">¡Mensaje Recibido!</h1>
          
          <p class="text-xl text-gray-600 mb-10 leading-relaxed">
            Gracias por contactar con Terencio. Nuestro equipo ya tiene tu mensaje y te responderemos en el menor tiempo posible (usualmente menos de 24h).
          </p>

          <div class="h-px bg-gray-100 w-full mb-10"></div>

          <p class="text-sm font-bold text-gray-500 uppercase tracking-widest mb-6">MIENTRAS ESPERAS...</p>

          <div class="grid sm:grid-cols-2 gap-4">
             <a href="/ofertas" class="group block p-6 bg-red-50 rounded-xl hover:bg-red-100 transition border border-red-100 text-left">
                <span class="material-icons-outlined text-3xl text-red-500 mb-3 group-hover:scale-110 transition">local_offer</span>
                <h3 class="font-bold text-gray-900">Mira las Ofertas</h3>
                <p class="text-sm text-gray-600 mt-1">Descubre los precios bajos de esta semana.</p>
             </a>

             <a href="/blog" class="group block p-6 bg-green-50 rounded-xl hover:bg-green-100 transition border border-green-100 text-left">
                <span class="material-icons-outlined text-3xl text-green-500 mb-3 group-hover:scale-110 transition">article</span>
                <h3 class="font-bold text-gray-900">Lee nuestro Blog</h3>
                <p class="text-sm text-gray-600 mt-1">Novedades y consejos sobre productos canarios.</p>
             </a>
          </div>

          <div class="mt-10">
            <Button href="/" variant="ghost">Volver al inicio</Button>
          </div>
       </div>

    </div>
  </div>
</Layout>
