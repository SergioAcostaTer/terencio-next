---
import { Image } from "astro:assets";
import carniceriaInterior from "../assets/images/supermercado-interior.webp";
import Button from "../components/ui/Button.astro";
import Icon from "../components/ui/Icon";
import PageHeader from "../components/ui/PageHeader.astro";
import Section from "../components/ui/Section.astro";
import Layout from "../layouts/Layout.astro";

// SEO Optimizado
const title = "Carnicería en Tenerife: Carne de Fiesta y Despiece Propio | Terencio";
const description = "La mejor carnicería de La Esperanza. Despiece propio diario, carne fresca, carne de fiesta preparada al momento y cortes a gusto del cliente. Venta a particulares y restaurantes.";
const canonical = "https://terencio.es/carniceria-tenerife";
---

<Layout title={title} description={description} canonical={canonical} image={carniceriaInterior.src}>
  
  <PageHeader 
    title="Carnicería Tradicional: <span class='text-red-300'>Corte a Cuchillo</span>"
    subtitle="Recuperamos el sabor de siempre. Realizamos despiece propio cada mañana para garantizar la máxima frescura y preparamos tu carne de fiesta al momento."
    badge="Especialistas en Carnes"
    badgeClass="bg-red-800/80 border border-red-400 text-red-100"
    backgroundImage={carniceriaInterior.src}
    bgClass="bg-red-900"
    gradientClass="bg-gradient-to-b from-red-900/90 via-red-900/60 to-red-900/90"
  >
    <div class="flex flex-wrap gap-4 justify-center">
      <Button href="#productos" variant="white" class="text-red-800 hover:bg-red-50 shadow-xl border-none font-bold px-8">
          Ver Cortes Destacados
      </Button>
      <Button href="/profesionales" variant="outline" class="border-white text-white hover:bg-white hover:text-red-900 font-bold px-8">
          Soy Restaurante
      </Button>
    </div>
  </PageHeader>

  <Section class="bg-white overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="relative order-2 md:order-1">
             <div class="absolute -inset-4 bg-red-50 rounded-[3rem] rotate-[-2deg] z-0"></div>
             <div class="absolute -inset-4 bg-gray-100 rounded-[3rem] rotate-[2deg] z-0 opacity-50"></div>
             
             <Image src={carniceriaInterior} alt="Carnicero cortando carne fresca en Terencio La Esperanza" class="relative z-10 rounded-3xl shadow-2xl w-full h-auto object-cover border-8 border-white transform hover:scale-[1.01] transition duration-500" width={600} height={400} />
             
             <!-- Floating Badge -->
             <div class="absolute -bottom-6 -right-6 bg-yellow-50 p-6 rounded-2xl shadow-xl z-20 border-2 border-yellow-200 text-center animate-bounce-slow hidden sm:block">
               <p class="text-red-900 font-black text-4xl leading-none mb-1">100%</p>
               <p class="text-xs font-bold text-gray-700 uppercase tracking-wider">Fresco Diario</p>
             </div>
        </div>
        
        <div class="prose prose-lg text-gray-600 order-1 md:order-2">
          <span class="text-red-600 font-bold uppercase tracking-widest text-sm bg-red-50 px-3 py-1 rounded-full">Maestros Carniceros</span>
          <h2 class="text-4xl font-bold text-gray-900 mb-6 mt-4">El secreto está en el origen y el corte</h2>
          <p>
            En <strong>Terencio Cash Market</strong> no trabajamos con carne envasada industrialmente llena de gases conservantes. Nuestro equipo de maestros carniceros realiza el <strong>despiece propio</strong> en nuestras instalaciones de La Esperanza cada madrugada. Esto nos permite ofrecerte cortes frescos, jugosos y con el sabor auténtico que ya no se encuentra en los grandes supermercados.
          </p>
          <p>
            ¿Buscas la auténtica <strong>Carne de Fiesta</strong> para tu guachinche, ventorrillo o evento familiar? La preparamos al momento, con dados limpios y seleccionados, con el adobo tradicional canario o al natural para que tú le des tu toque secreto.
          </p>
          
          <ul class="space-y-3 mt-8 not-prose">
             <li class="flex items-center gap-3">
                <Icon name="CircleCheck" className="text-red-600 shrink-0" /> 
                <span class="font-medium text-gray-800">Corte personalizado al grosor que desees</span>
             </li>
             <li class="flex items-center gap-3">
                <Icon name="CircleCheck" className="text-red-600 shrink-0" /> 
                <span class="font-medium text-gray-800">Cerdo y Res del país y de importación selecta</span>
             </li>
             <li class="flex items-center gap-3">
                <Icon name="CircleCheck" className="text-red-600 shrink-0" /> 
                <span class="font-medium text-gray-800">Precios directos de mayorista</span>
             </li>
          </ul>
        </div>
      </div>
    </div>
      </div>
    </div>
  </Section>

  <!-- Origen Local Section -->
  <section class="py-16 bg-white border-t border-gray-100">
      <div class="container mx-auto px-4">
          <div class="text-center mb-12">
              <span class="text-red-700 font-bold uppercase tracking-widest text-sm bg-red-50 px-3 py-1 rounded-full">Transparencia Total</span>
              <h2 class="text-3xl font-bold text-gray-900 mt-4">Conocemos a nuestros ganaderos por su nombre</h2>
              <p class="text-gray-500 max-w-2xl mx-auto mt-4">No somos una multinacional anónima. Compramos ganado local para apoyar al sector primario de Tenerife y garantizarte la máxima frescura.</p>
          </div>
          
          <div class="flex flex-wrap justify-center gap-8">
              <div class="flex items-center gap-4 bg-gray-50 px-6 py-4 rounded-full border border-gray-200 hover:border-red-200 transition">
                  <span class="w-10 h-10 bg-red-100 text-red-600 rounded-full flex items-center justify-center font-bold">JD</span>
                  <div>
                      <p class="font-bold text-gray-900 leading-none">José D.</p>
                      <p class="text-xs text-gray-500">Ganadero - La Esperanza</p>
                  </div>
              </div>
              <div class="flex items-center gap-4 bg-gray-50 px-6 py-4 rounded-full border border-gray-200 hover:border-red-200 transition">
                  <span class="w-10 h-10 bg-red-100 text-red-600 rounded-full flex items-center justify-center font-bold">MG</span>
                  <div>
                      <p class="font-bold text-gray-900 leading-none">Manuel G.</p>
                      <p class="text-xs text-gray-500">Granja Porcina - Fasnia</p>
                  </div>
              </div>
              <div class="flex items-center gap-4 bg-gray-50 px-6 py-4 rounded-full border border-gray-200 hover:border-red-200 transition">
                  <span class="w-10 h-10 bg-red-100 text-red-600 rounded-full flex items-center justify-center font-bold">AG</span>
                  <div>
                      <p class="font-bold text-gray-900 leading-none">Antonio G.</p>
                      <p class="text-xs text-gray-500">Cooperativa - El Hierro</p>
                  </div>
              </div>
          </div>
      </div>
  </section>



  <!-- Product Highlight List -->
  <section id="productos" class="py-20 bg-gray-50 border-t border-gray-200">
      <div class="container mx-auto px-4 max-w-7xl">
          <div class="text-center mb-16">
             <span class="text-red-600 font-bold uppercase tracking-widest text-sm">Nuestras Especialidades</span>
             <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mt-3">Cortes Estrella</h2>
             <p class="text-gray-500 mt-4 max-w-2xl mx-auto text-lg">Seleccionados por nuestros clientes como los mejores de la zona.</p>
          </div>
          
          <div class="grid md:grid-cols-3 gap-8">
              <!-- Card 1 -->
              <div class="bg-white rounded-[2rem] shadow-sm hover:shadow-2xl transition-all duration-300 overflow-hidden group border border-gray-100 flex flex-col">
                  <div class="h-64 bg-red-50 flex items-center justify-center text-9xl group-hover:scale-110 transition duration-500 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-t from-red-100/50 to-transparent"></div>
                    🥩
                    <div class="absolute top-6 right-6 bg-red-600 text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-lg">Top Ventas</div>
                  </div>
                  <div class="p-8 flex flex-col flex-grow">
                      <h3 class="font-bold text-2xl mb-3 text-gray-900 group-hover:text-red-700 transition-colors">Carne de Fiesta</h3>
                      <p class="text-gray-600 mb-6 leading-relaxed flex-grow">Dados de cerdo limpios, sin grasa excesiva y jugosos. Perfectos para freír con ajos y pimentón. Disponibles adobados o al natural.</p>
                      <a href="/contacto" class="w-full text-center bg-gray-50 hover:bg-red-50 text-gray-900 hover:text-red-700 font-bold py-3 rounded-xl transition-colors border border-gray-200 hover:border-red-200">Consultar Disponibilidad</a>
                  </div>
              </div>
              
              <!-- Card 2 -->
              <div class="bg-white rounded-[2rem] shadow-sm hover:shadow-2xl transition-all duration-300 overflow-hidden group border border-gray-100 flex flex-col">
                  <div class="h-64 bg-yellow-50 flex items-center justify-center text-9xl group-hover:scale-110 transition duration-500 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-t from-yellow-100/50 to-transparent"></div>
                    🍗
                    <div class="absolute top-6 right-6 bg-yellow-600 text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-lg">Económico</div>
                  </div>
                  <div class="p-8 flex flex-col flex-grow">
                      <h3 class="font-bold text-2xl mb-3 text-gray-900 group-hover:text-yellow-700 transition-colors">Pollo Fresco</h3>
                      <p class="text-gray-600 mb-6 leading-relaxed flex-grow">Enteros, pechugas fileteadas al momento, muslos o alas. Nada de congelado, todo frescura diaria y al mejor precio del mercado.</p>
                      <a href="/contacto" class="w-full text-center bg-gray-50 hover:bg-yellow-50 text-gray-900 hover:text-yellow-700 font-bold py-3 rounded-xl transition-colors border border-gray-200 hover:border-yellow-200">Consultar Disponibilidad</a>
                  </div>
              </div>

              <!-- Card 3 -->
              <div class="bg-white rounded-[2rem] shadow-sm hover:shadow-2xl transition-all duration-300 overflow-hidden group border border-gray-100 flex flex-col">
                  <div class="h-64 bg-orange-50 flex items-center justify-center text-9xl group-hover:scale-110 transition duration-500 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-t from-orange-100/50 to-transparent"></div>
                    🥓
                    <div class="absolute top-6 right-6 bg-orange-600 text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-lg">Tradición</div>
                  </div>
                  <div class="p-8 flex flex-col flex-grow">
                      <h3 class="font-bold text-2xl mb-3 text-gray-900 group-hover:text-orange-700 transition-colors">Chuletas y Costillas</h3>
                      <p class="text-gray-600 mb-6 leading-relaxed flex-grow">Chuletas de aguja, lomo veteado o costillar salado ideal para el potaje de berros. Te las cortamos al grosor que más te guste.</p>
                      <a href="/contacto" class="w-full text-center bg-gray-50 hover:bg-orange-50 text-gray-900 hover:text-orange-700 font-bold py-3 rounded-xl transition-colors border border-gray-200 hover:border-orange-200">Consultar Disponibilidad</a>
                  </div>
              </div>
          </div>
      </div>
  </section>

  <!-- CTA para Profesionales -->
  <section class="bg-slate-900 text-white py-24 text-center relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-full opacity-5 bg-[url('https://www.transparenttextures.com/patterns/food.png')]"></div>
      
      <!-- Decorative circles -->
      <div class="absolute top-0 right-0 w-96 h-96 bg-red-600 rounded-full filter blur-[120px] opacity-20 translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-red-600 rounded-full filter blur-[120px] opacity-20 -translate-x-1/2 translate-y-1/2"></div>

      <div class="container mx-auto px-4 relative z-10 max-w-4xl">
          <div class="inline-flex items-center gap-2 border border-red-500 bg-red-500/20 px-4 py-1.5 rounded-full text-red-300 text-xs font-bold uppercase tracking-wider mb-6">
             <Icon name="ChefHat" size={16} /> Servicio HORECA
          </div>
          <h2 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">¿Tienes un restaurante o guachinche?</h2>
          <p class="mb-10 text-slate-300 max-w-2xl mx-auto text-xl leading-relaxed">
            Olvídate de limpiar carne y perder tiempo. Preparamos pedidos grandes de carne <strong>cortada y envasada al vacío</strong> según tus necesidades exactas. Reduce mermas y aumenta tu rentabilidad.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <Button href="/profesionales" variant="primary" class="bg-red-600 text-white hover:bg-red-700 border-none shadow-lg shadow-red-900/50 px-10 py-4 text-lg">
                Consultar Tarifas HORECA
            </Button>
            <Button href="tel:922550067" variant="outline" class="border-gray-600 text-gray-300 hover:bg-white hover:text-red-900 hover:border-white px-10 py-4 text-lg">
                <Icon name="Phone" className="mr-2"/> Llamar a Carnicería
            </Button>
          </div>
      </div>
  </section>

  <!-- FAQ Carnicería -->
  <section class="py-16 bg-white">
      <div class="container mx-auto px-4 max-w-3xl">
          <h2 class="text-3xl font-bold text-center mb-10 text-gray-900">Preguntas Frecuentes sobre Carnicería</h2>
          <div class="space-y-4">
              <details class="group bg-gray-50 p-6 rounded-2xl border border-gray-100 open:bg-white open:shadow-lg transition-all duration-300">
                  <summary class="flex justify-between items-center font-bold text-lg cursor-pointer list-none text-gray-800">
                      ¿Preparan la carne para llevar de viaje?
                      <span class="transition-transform group-open:rotate-180"><Icon name="ChevronDown" /></span>
                  </summary>
                  <p class="text-gray-600 mt-4 leading-relaxed">Sí, podemos envasar tu pedido al vacío para que se conserve perfectamente durante el viaje entre islas o si vas a congelarla.</p>
              </details>
              <details class="group bg-gray-50 p-6 rounded-2xl border border-gray-100 open:bg-white open:shadow-lg transition-all duration-300">
                  <summary class="flex justify-between items-center font-bold text-lg cursor-pointer list-none text-gray-800">
                      ¿Hay que encargar la Carne de Fiesta?
                      <span class="transition-transform group-open:rotate-180"><Icon name="ChevronDown" /></span>
                  </summary>
                  <p class="text-gray-600 mt-4 leading-relaxed">Normalmente tenemos stock diario, pero para cantidades grandes (más de 5kg) recomendamos llamar con antelación para tenerla lista y que no tengas que esperar.</p>
              </details>
          </div>
          
           <!-- Geographic Keywords Injection -->
          <div class="mt-12 text-center text-sm text-gray-500 bg-gray-50 p-6 rounded-xl border border-gray-100">
            <p>
              Estamos estratégicamente ubicados en La Esperanza, a <strong>5 minutos de la Vía de Ronda</strong> y en plena carretera general subiendo hacia el Teide.
              La mejor opción si vienes de La Laguna, Santa Cruz o vas de camino a Las Raíces.
            </p>
          </div>
      </div>
  </section>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ButcherShop",
      "name": "Carnicería Terencio",
      "image": "https://terencio.es/assets/images/supermercado-interior.webp",
      "description": "Carnicería tradicional con despiece propio diario en La Esperanza, Tenerife. Especialistas en carne de fiesta y cortes a medida.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Ctra. La Esperanza 22",
        "addressLocality": "San Cristóbal de La Laguna",
        "postalCode": "38291",
        "addressRegion": "Santa Cruz de Tenerife",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 28.468,
        "longitude": -16.365
      },
      "url": "https://terencio.es/carniceria-tenerife",
      "telephone": "+34922550067",
      "priceRange": "$$",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday"
          ],
          "opens": "08:00",
          "closes": "21:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Sunday",
          "opens": "08:30",
          "closes": "20:30"
        }
      ]
    }
  </script>

</Layout>