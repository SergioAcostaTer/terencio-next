---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

interface Props {
  maxItems?: number;
  posts?: any[]; // Allow passing posts directly
}

const { maxItems, posts: providedPosts } = Astro.props;

let newsData = providedPosts;

if (!newsData) {
  newsData = await getCollection('noticias');
}

// Sort by date mostly, but prioritize breaking news if needed
const sortedNews = newsData.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const breakingNews = sortedNews.find(n => n.data.isBreaking);
const heroNews = breakingNews || sortedNews[0];

// Filter out the hero from the rest list if there is one
const remainingNews = heroNews 
    ? sortedNews.filter(n => n.slug !== heroNews.slug) 
    : [];

// Sidebar gets next 2 items
const sidebarNews = remainingNews.slice(0, 2);

// Grid gets the rest (limited by maxItems if provided)
const gridNews = remainingNews.slice(2, maxItems ? 2 + maxItems : undefined);

const formatDate = (date: Date) => {
    return date.toLocaleDateString('es-ES', { day: 'numeric', month: 'long' });
};
---

<div class="news-portal font-sans">
    
    <!-- Breaking Bar -->
    {breakingNews && (
        <div class="bg-red-700 text-white px-3 sm:px-4 py-2.5 sm:py-2 text-xs sm:text-sm font-bold flex items-center gap-2 sm:gap-3 mb-4 sm:mb-6 rounded-md shadow-sm">
            <span class="animate-pulse flex h-2.5 w-2.5 sm:h-3 sm:w-3 rounded-full bg-white opacity-75 flex-shrink-0"></span>
            <span class="uppercase tracking-wider flex-shrink-0">ÚLTIMA HORA:</span>
            <a href={`/noticias/${breakingNews.slug}`} class="hover:underline truncate min-w-0">{breakingNews.data.title}</a>
        </div>
    )}

    {heroNews && (
    <div class="grid lg:grid-cols-3 gap-6 sm:gap-8 mb-8 sm:mb-12">
        
        <!-- Main Hero Article (Columns 1 & 2) -->
        <article class="lg:col-span-2 group relative h-[350px] sm:h-[450px] lg:h-[500px] overflow-hidden rounded-xl shadow-lg">
            <a href={`/noticias/${heroNews.slug}`} class="block w-full h-full">
                <Image 
                    src={heroNews.data.image as any} 
                    alt={heroNews.data.title} 
                    widths={[640, 900]}
                    sizes="(max-width: 768px) 100vw, 66vw"
                    quality={70}
                    loading="eager" 
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
                <div class="absolute bottom-0 left-0 p-8 w-full">
                    <span class="inline-block bg-green-700 text-white text-[10px] sm:text-xs font-bold px-2 sm:px-3 py-1 rounded-sm uppercase tracking-wide mb-2 sm:mb-3">
                        {heroNews.data.category || 'Actualidad'}
                    </span>
                    <h2 class="text-xl sm:text-2xl md:text-4xl lg:text-5xl font-bold text-white leading-tight mb-2 sm:mb-3 group-hover:underline decoration-2 underline-offset-4 shadow-black drop-shadow-md">
                        {heroNews.data.title}
                    </h2>
                    <p class="text-gray-100 text-sm sm:text-base md:text-lg line-clamp-2 md:w-3/4 drop-shadow-md hidden sm:block">
                        {heroNews.data.description}
                    </p>
                </div>
            </a>
        </article>

        <!-- Sidebar Top Stories (Column 3) -->
        <div class="space-y-4 sm:space-y-6 flex flex-col lg:h-[500px]">
            <div class="flex items-center justify-between border-b-2 border-green-700 pb-2 mb-2">
                <h3 class="font-bold text-lg sm:text-xl text-gray-900">Lo más leído</h3>
                <span class="text-green-800 text-xs sm:text-sm font-bold">Top 3</span>
            </div>
            
            {sidebarNews.map((news, index) => (
                <article class="flex-1 group border-b border-gray-200 last:border-0 pb-3 sm:pb-4 last:pb-0">
                    <a href={`/noticias/${news.slug}`} class="flex gap-3 sm:gap-4 h-full">
                        <div class="w-1/3 h-20 sm:h-24 rounded-lg overflow-hidden flex-shrink-0">
                            <Image src={news.data.image as any} alt={news.data.title} class="w-full h-full object-cover transition duration-300 group-hover:opacity-80" width={150} height={150} quality={70} loading="lazy" />
                        </div>
                        <div class="w-2/3 flex flex-col justify-between min-w-0">
                            <div class="min-w-0">
                                <span class="text-[10px] sm:text-xs font-bold text-green-800 uppercase mb-1 block">{news.data.category}</span>
                                <h4 class="font-bold text-sm sm:text-base text-gray-900 leading-snug group-hover:text-green-800 transition line-clamp-2 sm:line-clamp-3">
                                    {news.data.title}
                                </h4>
                            </div>
                            <!-- Improved contrast for date -->
                            <time class="text-[10px] sm:text-xs text-gray-500 mt-1 sm:mt-2 block font-medium">{formatDate(news.data.pubDate)}</time>
                        </div>
                    </a>
                </article>
            ))}
            
            <div class="mt-auto bg-gray-100 p-3 sm:p-4 rounded-lg border border-gray-200 text-center hidden lg:block">
                <p class="text-xs sm:text-sm text-gray-700 mb-2 font-medium">¿Quieres recibir nuestras ofertas?</p>
                <a href="#newsletter" class="block w-full bg-gray-900 text-white text-xs sm:text-sm font-bold py-2 rounded hover:bg-gray-800 transition">Suscribirse</a>
            </div>
        </div>
    </div>
    )}

    {!heroNews && (
        <div class="py-12 text-center bg-gray-50 rounded-lg">
            <p class="text-gray-500">No hay noticias destacadas en este momento.</p>
        </div>
    )}

    <!-- Secondary Grid -->
    {gridNews.length > 0 && (
        <div class="border-t border-gray-200 pt-6 sm:pt-8">
            <h3 class="font-bold text-xl sm:text-2xl text-gray-900 mb-4 sm:mb-6">Otras noticias</h3>
            <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4 sm:gap-6">
                {gridNews.map(news => (
                    <a href={`/noticias/${news.slug}`} class="group">
                        <article class="h-full flex flex-col">
                            <div class="mb-3 sm:mb-4 overflow-hidden rounded-lg h-40 sm:h-48">
                                <Image 
                                    src={news.data.image as any} 
                                    alt={news.data.title} 
                                    class="w-full h-full object-cover transform transition duration-500 group-hover:scale-105"
                                    width={400}
                                    height={300}
                                    quality={70}
                                    loading="lazy"
                                />
                            </div>
                            <span class="text-[10px] sm:text-xs font-bold text-gray-600 mb-1 sm:mb-2 block">{formatDate(news.data.pubDate)} · {news.data.category}</span>
                            <h4 class="font-bold text-base sm:text-lg md:text-xl text-gray-900 group-hover:text-green-800 transition leading-snug mb-2">
                                {news.data.title}
                            </h4>
                            <p class="text-gray-600 text-xs sm:text-sm line-clamp-2">{news.data.description}</p>
                        </article>
                    </a>
                ))}
            </div>
        </div>
    )}

</div>