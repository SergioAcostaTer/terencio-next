---
import LocationMap from "./LocationMap.astro";
import Button from "./ui/Button.astro";
import Icon from "./ui/Icon";

interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<section class={`bg-gray-50 py-16 ${className}`}>
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
        <h2 class="text-3xl font-bold mb-4 text-gray-900">Visítanos en La Laguna</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Estamos estratégicamente ubicados para dar servicio a La Laguna y Santa Cruz con parking gratuito propio.</p>
    </div>

     <div class="text-center my-8">
        <Button 
            href="https://www.google.com/maps/search/?api=1&query=Terencio+Cash+Market" 
            target="_blank" 
            variant="primary" 
            class="w-full sm:w-auto gap-3 py-4 px-8 text-base sm:text-lg font-bold shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-105 group"
        >
            <Icon name="Navigation" size={24} className="group-hover:rotate-12 transition-transform" />
            <span>Abrir en Google Maps</span>
            <Icon name="ExternalLink" size={18} className="opacity-70" />
        </Button>
    </div>
    
    <div class="max-w-5xl mx-auto bg-white p-4 rounded-2xl shadow-xl border border-gray-200">
        <LocationMap heightClass="h-[400px] md:h-[500px]" />
    </div>

    <div class="text-center mt-8">
        <Button 
            href="https://www.google.com/maps/search/?api=1&query=Terencio+Cash+Market" 
            target="_blank" 
            variant="primary" 
            class="w-full sm:w-auto gap-3 py-4 px-8 text-base sm:text-lg font-bold shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-105 group"
        >
            <Icon name="Navigation" size={24} className="group-hover:rotate-12 transition-transform" />
            <span>Abrir en Google Maps</span>
            <Icon name="ExternalLink" size={18} className="opacity-70" />
        </Button>
    </div>
  </div>
</section>
