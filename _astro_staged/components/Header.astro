---
import siteData from "../data/siteData.json";
import navigation from "../data/navigation.json";
import StoreStatus from "./StoreStatus.astro";
import Icon from "./ui/Icon";
import { Image } from "astro:assets";
import logo from "../assets/images/logo.webp";
---

<header class="fixed top-0 w-full z-[100] bg-white shadow-md transition-all duration-300 flex flex-col font-sans" id="main-header">
  
  <!-- Barra Superior (Desktop) - Información crítica -->
  <div class="hidden md:flex bg-brand-primary text-white text-xs py-2 justify-between px-6 lg:px-8 border-b border-green-800">
    <div class="flex gap-6">
       <a href="https://g.page/r/CWkyvLywov7bEBM/review" target="_blank" class="flex items-center gap-1 font-medium hover:text-yellow-200 transition">
          <Icon name="MapPin" size={14}/> Ctra. La Esperanza 22, La Laguna
       </a>
       <span class="flex items-center gap-1 font-bold text-yellow-300 animate-pulse">
          <Icon name="Calendar" size={14}/> ¡ABIERTO DOMINGOS!
       </span>
    </div>
    <div class="flex gap-6">
       <a href="/profesionales" class="hover:text-yellow-200 transition font-medium">Zona Profesionales HORECA</a>
       <a href={`tel:${siteData.contact.phoneRaw}`} class="flex items-center gap-1 font-bold hover:text-yellow-200 transition">
          <Icon name="Phone" size={14}/> {siteData.contact.phone}
       </a>
    </div>
  </div>

  <div class="h-[70px] md:h-[80px] container mx-auto px-4 lg:px-6 flex items-center justify-between flex-shrink-0 bg-white relative z-50">
    
    <!-- Mobile Left: Hamburger -->
    <button id="menu-toggle" class="md:hidden flex items-center justify-center w-12 h-12 rounded-xl text-gray-800 focus:outline-none hover:bg-gray-100 transition" aria-label="Menú Principal">
      <span class="material-icons-outlined text-3xl" id="menu-icon">menu</span>
    </button>

    <!-- Brand / Logo -->
    <a href="/" class="flex items-center gap-2 relative group" aria-label="Terencio Cash Market Inicio">
      <div class="h-8 md:h-12 flex items-center">
        <Image class="h-full w-auto object-contain transition-transform group-hover:scale-105" src={logo} alt="Logotipo Terencio Supermercado" width={48} height={48} loading="eager" />
      </div>
      <div class="flex flex-col justify-center -space-y-1">
        <span class="text-3xl lg:text-4xl font-black text-[#c81010] tracking-tighter leading-none capitalize" style="font-family: Verdana, sans-serif;">Terencio</span>
        <span class="text-lg lg:text-base text-[#007236] font-extrabold italic capitalize tracking-wider leading-none">Cash Market</span>
      </div>
    </a>

    <!-- Desktop Menu -->
    <nav aria-label="Navegación Desktop Principal" class="hidden md:block">
      <ul class="flex items-center gap-1 lg:gap-2 m-0 p-0 list-none">
      {navigation.main.map(link => (
        <li class="relative group">
          <a 
            href={link.href} 
            class:list={[
              "text-sm lg:text-[15px] font-bold transition-all flex items-center gap-1 px-3 py-2 rounded-lg",
              (link as any).color === 'red' ? "text-red-700 bg-red-50 hover:bg-red-100" : 
              (link as any).color === 'slate' ? "text-slate-800 bg-slate-100 hover:bg-slate-200" : 
              "text-gray-800 hover:text-brand-primary hover:bg-gray-50"
            ]}
          >
            {link.label}
            {link.children && <Icon name="ChevronDown" size={14} className="mt-0.5 group-hover:rotate-180 transition-transform text-gray-500" />}
          </a>
          
          {/* Dropdown Menu */}
          {link.children && (
            <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform group-hover:translate-y-0 translate-y-2 z-50">
               <ul class="bg-white shadow-xl rounded-xl border border-gray-100 p-2 w-64 overflow-hidden ring-1 ring-black ring-opacity-5 m-0 list-none">
                  {link.children.map(child => (
                    <li>
                      <a href={child.href} class="flex items-center gap-3 px-4 py-3 text-gray-800 hover:bg-green-50 hover:text-green-900 rounded-lg text-sm font-medium transition-colors group/item">
                      <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-600 group-hover/item:bg-green-200 group-hover/item:text-green-800 transition">
                         {child.label.includes('Carnicería') ? <span class="text-base">🥩</span> :
                          child.label.includes('Quesos') ? <span class="text-base">🧀</span> :
                          child.label.includes('Hierro') ? <span class="text-base">🍍</span> :
                          child.label.includes('Cash') ? <span class="text-base">🛒</span> :
                          <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>}
                      </div>
                      <div class="flex flex-col">
                          <span class="leading-none">{child.label}</span>
                      </div>
                      </a>
                    </li>
                  ))}
               </ul>
            </div>
          )}
        </li>
      ))}
      
      <li class="list-none md:ml-2">
        <a 
          href={navigation.cta.href} 
          class="ml-4 bg-brand-primary text-white px-6 py-2.5 rounded-xl font-bold hover:bg-green-800 transition-all shadow-md hover:shadow-lg text-sm flex items-center gap-2 transform hover:-translate-y-0.5"
        >
          {navigation.cta.label}
          <Icon name="ArrowRight" size={16} />
        </a>
      </li>
      </ul>
    </nav>

    <!-- Mobile Right: Ofertas Icon -->
    <a href="/ofertas" class="md:hidden flex items-center justify-center w-12 h-12 text-red-700 bg-red-50 rounded-xl active:scale-95 transition" aria-label="Ver Ofertas">
      <span class="material-icons-outlined text-2xl animate-pulse">local_offer</span>
    </a>
  </div>

  <StoreStatus />

  <!-- Mobile Menu Overlay -->
  <nav aria-label="Navegación Móvil Principal" id="mobile-menu" class="fixed top-[105px] left-0 w-full h-[calc(100dvh-105px)] bg-white z-[70] transform translate-x-full transition-transform duration-300 md:hidden overflow-hidden pb-6 shadow-inner">
    <ul class="flex flex-col p-6 gap-2 m-0 list-none">
      {navigation.main.map((link, index) => (
        <li class="mb-2">
          <div class:list={[
            "flex items-center justify-between border rounded-xl overflow-hidden shadow-sm transition-colors",
            (link as any).color === 'red' ? "border-red-500 bg-red-700 text-white" : 
            (link as any).color === 'slate' ? "border-slate-600 bg-slate-900 text-white" : "border-gray-200 bg-white"
          ]}>
            <a 
              href={link.href} 
              class:list={[
                "font-bold py-3.5 px-4 block flex-grow mobile-link flex items-center gap-3",
                (link as any).color === 'red' || (link as any).color === 'slate' ? "text-white" : "text-[17px] text-gray-800"
              ]}
            >
              { (link as any).color === 'red' && <span class="material-icons-outlined">restaurant_menu</span> }
              { (link as any).color === 'slate' && <span class="material-icons-outlined">storefront</span> }
              <span>{link.label}</span>
              { ((link as any).color === 'red' || (link as any).color === 'slate') && <span class="material-icons-outlined ml-auto">arrow_forward</span> }
            </a>
            {link.children && (
              <button 
                class="p-3.5 text-gray-600 hover:text-green-800 bg-gray-50/50 border-l border-gray-100 submenu-toggle focus:outline-none transition-all flex items-center justify-center self-stretch" 
                data-index={index}
                aria-label={`Abrir submenú de ${link.label}`}
              >
                <span class="material-icons-outlined text-xl transition-transform">expand_more</span>
              </button>
            )}
          </div>
          
          {link.children && (
            <ul id={`submenu-${index}`} class="hidden bg-gray-50 rounded-b-xl -mt-1 pt-2 pb-1 border-x border-b border-gray-200 list-none m-0 shadow-inner">
              {link.children.map(child => (
                  <li class="border-b border-gray-100 last:border-0 mx-2">
                    <a href={child.href} class="text-[15px] text-gray-700 mobile-link block py-3 px-3 font-medium hover:text-green-800 hover:bg-green-50 rounded-lg transition-colors flex items-center gap-2">
                      <span class="material-icons-outlined text-sm text-green-700">chevron_right</span>
                      {child.label}
                    </a>
                  </li>
              ))}
            </ul>
          )}
        </li>
      ))}
      

      <li class="mt-4 pt-4 pb-8 border-t border-gray-100 text-center text-sm text-gray-600">
          <p class="font-medium mb-2 text-gray-700">Síguenos en redes</p>
          <div class="flex justify-center gap-6">
             <a href={siteData.social.facebook} target="_blank" class="text-blue-600 bg-blue-50 p-2.5 rounded-full hover:bg-blue-100 transition flex items-center justify-center" aria-label="Facebook">
                 <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                     <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
                 </svg>
             </a>
             <a href={siteData.social.instagram} target="_blank" class="text-pink-600 bg-pink-50 p-2.5 rounded-full hover:bg-pink-100 transition flex items-center justify-center" aria-label="Instagram">
                 <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                     <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
                 </svg>
             </a>
          </div>
          <div class="mt-4 text-xs text-gray-500">
            <p>Terencio Cash Market</p>
            <p>La Laguna, Tenerife</p>
          </div>
      </li>
    </ul>
  </nav>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');

    if (menuToggle && mobileMenu && menuIcon) {
      const toggleMenu = () => {
        const isClosed = mobileMenu.classList.contains('translate-x-full');
        if (isClosed) {
          mobileMenu.classList.remove('translate-x-full');
          menuIcon.textContent = 'close';
          document.body.style.overflow = 'hidden'; 
          document.documentElement.style.overflow = 'hidden';
        } else {
          mobileMenu.classList.add('translate-x-full');
          menuIcon.textContent = 'menu';
          document.body.style.overflow = '';
          document.documentElement.style.overflow = '';
        }
      };

      menuToggle.addEventListener('click', toggleMenu);

      document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('translate-x-full');
          menuIcon.textContent = 'menu';
          document.body.style.overflow = '';
          document.documentElement.style.overflow = '';
        });
      });

      // Accordion Logic
      document.querySelectorAll('.submenu-toggle').forEach(button => {
        button.addEventListener('click', (e) => {
          e.stopPropagation();
          const index = button.getAttribute('data-index');
          const submenu = document.getElementById(`submenu-${index}`);
          const arrow = button.querySelector('span');

          if (submenu) {
             const isHidden = submenu.classList.contains('hidden');
             if (isHidden) {
               submenu.classList.remove('hidden');
               if(arrow) arrow.style.transform = 'rotate(180deg)';
             } else {
               submenu.classList.add('hidden');
               if(arrow) arrow.style.transform = 'rotate(0deg)';
             }
          }
        });
      });
    }
  });
</script>