---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

interface Props {
  maxItems?: number;
  excludeSlug?: string;
  posts?: any[]; // Allow passing posts directly
}

const { maxItems, excludeSlug, posts: providedPosts } = Astro.props;

// Fetch if not provided
let posts = providedPosts;
if (!posts) {
  const allPosts = await getCollection('blog');
  posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
}

// Filter excludeSlug
if (excludeSlug) {
  posts = posts.filter(p => p.slug !== excludeSlug);
}

// Limit
if (maxItems) {
  posts = posts.slice(0, maxItems);
}

const formatDate = (date: Date) => {
    return date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6 sm:gap-8">
  {posts.map((post) => (
    <a href={`/blog/${post.slug}`} class="group flex flex-col h-full bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 overflow-hidden hover:-translate-y-1">
      <div class="h-48 sm:h-56 overflow-hidden relative">
        {post.data.image && (
          <Image 
            src={post.data.image} 
            alt={post.data.title}
            class="w-full h-full object-cover transform group-hover:scale-110 transition duration-700"
            width={400}
            height={300}
          />
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4 sm:p-6">
            <span class="text-white font-bold text-xs sm:text-sm bg-green-600 px-3 py-1 rounded-full">Leer artículo &rarr;</span>
        </div>
      </div>
      
      <div class="p-4 sm:p-6 flex flex-col flex-grow">
        <div class="flex items-center gap-2 text-[10px] sm:text-xs font-bold text-green-700 mb-2 sm:mb-3 uppercase tracking-wider">
          <span>{post.data.tags ? post.data.tags[0] : 'Blog'}</span>
          <span class="text-gray-300">•</span>
          <span class="text-gray-500 font-normal normal-case">{formatDate(post.data.pubDate)}</span>
        </div>
        
        <h3 class="text-lg sm:text-xl font-bold text-gray-900 mb-2 sm:mb-3 leading-tight group-hover:text-green-700 transition-colors">
          {post.data.title}
        </h3>
        
        <p class="text-gray-600 text-xs sm:text-sm line-clamp-3 mb-4 flex-grow">
          {post.data.description}
        </p>
      </div>
    </a>
  ))}
</div>