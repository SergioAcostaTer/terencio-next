---
interface Props {
  title: string;
  description: string;
  icon: string;
  link?: string;
}

const { title, description, icon, link } = Astro.props;

const icons: Record<string, string> = {
  store: "🏪",
  "shopping-cart": "🛒",
  utensils: "🍽️",
  parking: "🅿️",
};

const displayIcon = icons[icon] ?? "✨";
---

{link ? (
  <a
    href={link}
    class="block bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-all group cursor-pointer"
  >
    <div class="w-12 h-12 bg-green-50 rounded-lg flex items-center justify-center text-green-700 mb-4 group-hover:bg-green-600 group-hover:text-white transition-colors">
      <span class="font-bold text-xl select-none">
        {displayIcon}
      </span>
    </div>

    <h3 class="text-xl font-bold text-gray-900 mb-2">{title}</h3>
    <p class="text-gray-600 mb-4 leading-relaxed">{description}</p>

    <span class="text-green-700 font-semibold inline-flex items-center gap-1 group-hover:underline">
      Saber más <span>&rarr;</span>
    </span>
  </a>
) : (
  <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
    <div class="w-12 h-12 bg-green-50 rounded-lg flex items-center justify-center text-green-700 mb-4">
      <span class="font-bold text-xl select-none">
        {displayIcon}
      </span>
    </div>

    <h3 class="text-xl font-bold text-gray-900 mb-2">{title}</h3>
    <p class="text-gray-600 mb-4 leading-relaxed">{description}</p>
  </div>
)}
