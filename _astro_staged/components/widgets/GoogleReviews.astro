---
import reviews from "../../data/reviews.json";

// Helper to render stars
const renderStars = (rating: number) => {
  return Array.from({ length: 5 }, (_, i) => i < rating);
};

const googleReviewUrl = "https://g.page/r/CWkyvLywov7bEBM/review";
const googleInfo = {
    rating: "4.0",
    reviewCount: "463",
    bestRating: "5",
    worstRating: "1"
}
const googleIcon = "https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg";
---

<section class="bg-white py-12 border-t border-gray-100">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-2">
         <img src={googleIcon} alt="Google Logo" class="w-8 h-8" />
         <div>
            <h2 class="text-xl font-bold text-gray-900 leading-none">Reseñas de Google</h2>
            <div class="flex items-center gap-1 text-sm text-gray-500 mt-1">
                <span class="font-bold text-gray-800">{googleInfo.rating}</span>
                <div class="flex text-yellow-400 text-xs">
                    <span class="material-icons-outlined">star</span>
                    <span class="material-icons-outlined">star</span>
                    <span class="material-icons-outlined">star</span>
                    <span class="material-icons-outlined">star</span>
                    <span class="material-icons-outlined">star</span>
                </div>
                <span>({googleInfo.reviewCount} reseñas)</span>
            </div>
         </div>
      </div>
      <a href={googleReviewUrl} target="_blank" class="text-blue-600 font-medium hover:underline text-sm hidden sm:block">
        Escribir una reseña
      </a>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
      {reviews.map((review) => (
        <div class="bg-gray-50 p-4 rounded-xl border border-gray-100 flex flex-col h-full">
           <div class="flex items-start justify-between mb-3">
              <div class="flex items-center gap-3">
                  <div class={`w-10 h-10 rounded-full flex items-center justify-center text-white font-bold ${review.color || 'bg-gray-400'}`}>
                      {review.avatar}
                  </div>
                  <div>
                      <div class="font-bold text-sm text-gray-900 line-clamp-1">{review.author}</div>
                      <div class="text-xs text-gray-500">{review.date}</div>
                  </div>
              </div>
              <img src={googleIcon} alt="G" class="w-4 h-4 opacity-50" />
           </div>

           <div class="flex text-yellow-500 mb-2">
               {renderStars(review.rating).map(isFull => (
                  <span class="material-icons-outlined text-sm">{isFull ? 'star' : 'star_border'}</span>
               ))}
           </div>

           <p class="text-sm text-gray-600 mb-4 flex-grow leading-relaxed">"{review.text}"</p>

           {review.photos && (
               <div class="mb-3">
                   <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full font-bold flex items-center w-fit gap-1">
                       <span class="material-icons-outlined text-xs">photo_camera</span> Con fotos
                   </span>
               </div>
           )}

           {review.response && (
               <div class="mt-auto bg-white p-3 rounded-lg border border-gray-200 text-xs">
                   <p class="font-bold text-gray-800 mb-1">Respuesta del propietario:</p>
                   <p class="text-gray-500 italic">{review.response}</p>
               </div>
           )}
        </div>
      ))}
    </div>
    
    <div class="text-center mt-8 sm:hidden">
        <a href={googleReviewUrl} target="_blank" class="text-blue-600 font-bold hover:underline">
            Ver todas las reseñas
        </a>
    </div>

  </div>
</section>