---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import heroBg from "../assets/images/hero-bg.webp";
import Icon from "../components/ui/Icon";

interface Props {
  title?: string;
  subtitle?: string;
  badge?: string;
  primaryCta?: {
    text: string;
    href: string;
  };
  secondaryCta?: {
    text: string;
    href: string;
  };
  backgroundImage?: ImageMetadata;
}

const {
  title = "Tu Compra Diaria y <span class='text-green-300'>Cash & Carry</span> para Profesionales",
  subtitle = "Calidad, frescura y los mejores precios en un solo lugar. Abierto todos los días para particulares y empresas de hostelería.",
  badge = "📍 La Laguna, Tenerife",
  primaryCta = { text: "Cómo llegar", href: "#donde-estamos" },
  secondaryCta,
  backgroundImage = heroBg,
} = Astro.props;
---

<section class="relative bg-green-900 text-white overflow-hidden min-h-[350px] md:min-h-[450px] flex items-center">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <Image 
      src={backgroundImage} 
      alt="Fondo de Terencio Supermercado" 
      class="w-full h-full object-cover opacity-20"
      widths={[640, 1280, 1920]}
      sizes="100vw"
      format="webp"
      quality={60}
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-green-900/95 via-green-900/80 to-transparent sm:from-green-900 sm:to-transparent/10"></div>
  </div>

  <div class="container mx-auto px-4 lg:px-6 relative z-10 py-8 lg:py-16 flex flex-col justify-center h-full">
    <div class="max-w-3xl animate-fade-in-up">
      <span class="inline-flex items-center gap-2 py-1.5 px-4 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-green-50 text-sm font-bold tracking-wide uppercase mb-8 shadow-sm">
        {badge}
      </span>
      
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-[1.1] mb-6 tracking-tight text-white drop-shadow-sm" set:html={title} />
      
      <p class="text-base md:text-lg text-green-50 mb-8 leading-relaxed max-w-2xl opacity-90 font-medium">
        {subtitle}
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 items-center sm:items-start w-full sm:w-auto">
        <a 
          href={primaryCta.href} 
          class="group flex w-full sm:w-auto justify-center items-center gap-2 bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-xl font-bold text-base md:text-lg transition-all shadow-lg hover:shadow-red-900/30 transform hover:-translate-y-1 focus:ring-4 focus:ring-red-500/50 outline-none"
          aria-label={`${primaryCta.text} - Ir a la sección`}
        >
          {primaryCta.text}
          <Icon name="ArrowRight" size={24} className="group-hover:translate-x-1 transition-transform" />
        </a>
        
        {secondaryCta && (
          <a 
            href={secondaryCta.href} 
            class="flex w-full sm:w-auto justify-center items-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-md text-white px-6 py-3 rounded-xl font-bold text-base md:text-lg transition-all border border-white/20 hover:border-white/40 focus:ring-4 focus:ring-white/30 outline-none"
             aria-label={`${secondaryCta.text} - Información adicional`}
          >
            {secondaryCta.text}
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translate3d(0, 30px, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
</style>
