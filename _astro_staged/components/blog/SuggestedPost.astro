---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Icon from '../ui/Icon';

interface Props {
  currentSlug?: string;
  tags?: string[];
  // Manual override props
  post?: any;
  title?: string;
  subtitle?: string;
  image?: string | ImageMetadata;
  url?: string;
  compact?: boolean;
}

const { currentSlug, tags, post: manualPost, title, subtitle, image, url, compact } = Astro.props;

// Fetch all posts
const allPosts = await getCollection('blog');

// Determine post to show
let relatedPost = manualPost;

if (!relatedPost && !title) {
    if (tags && tags.length > 0) {
        // Try to find a post with at least one matching tag, excluding current
        relatedPost = allPosts.find(post => 
             (!currentSlug || post.slug !== currentSlug) && 
            post.data.tags?.some(tag => tags.includes(tag))
        );
    }

    // Fallback: Just get the most recent post that isn't the current one
    if (!relatedPost) {
        relatedPost = allPosts
            .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
            .find(post => !currentSlug || post.slug !== currentSlug);
    }
}

// Construct display data
const displayData = title ? {
    title: title,
    description: "Artículo destacado", // Default or accept prop
    image: image,
    slug: url || '#', // Handle URL
    subtitle: subtitle || 'Relacionado'
} : relatedPost ? {
    title: relatedPost.data.title,
    description: relatedPost.data.description,
    image: relatedPost.data.image,
    slug: relatedPost.slug,
    subtitle: 'Sigue leyendo'
} : null;

if (!displayData) return null;

// Adjust URL construction
const postUrl = title ? (url || '#') : `/blog/${displayData.slug}`;

---

{displayData && (
  <aside class={`my-12 not-prose ${compact ? 'max-w-sm mx-auto md:max-w-none' : ''}`}>
    <a href={postUrl} class="block group relative overflow-hidden rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300">
      
      <div class="absolute inset-0 bg-gray-900">
         {displayData.image && (
            <Image 
                src={displayData.image as any} 
                alt={displayData.title}
                class="w-full h-full object-cover opacity-40 group-hover:opacity-30 transition duration-500 scale-100 group-hover:scale-105"
                width={800}
                height={300}
            />
         )}
      </div>

      <div class="relative z-10 p-8 md:p-10 flex flex-col md:flex-row gap-6 items-start md:items-center justify-between">
         <div class="flex-1">
            <span class="inline-block bg-green-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-3">
                {displayData.subtitle}
            </span>
            <h3 class={`font-bold text-white mb-2 leading-tight group-hover:underline decoration-2 underline-offset-4 ${compact ? 'text-lg' : 'text-xl md:text-2xl'}`}>
                {displayData.title}
            </h3>
            {!compact && (
                <p class="text-gray-200 text-sm line-clamp-2 hidden md:block">
                    {displayData.description}
                </p>
            )}
         </div>
         
         <div class="bg-white text-green-900 font-bold py-3 px-6 rounded-full flex items-center gap-2 group-hover:bg-green-50 transition shrink-0">
            Leer artículo
            <Icon name="ArrowRight" size={20} />
         </div>
      </div>
    </a>
  </aside>
)}
