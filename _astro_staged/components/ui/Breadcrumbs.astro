---
import Icon from './Icon';

const { pathname } = Astro.url;
// Remove trailing slash if present for consistency, split by /, filter empty
const paths = pathname.replace(/\/$/, '').split('/').filter(Boolean);

const breadcrumbs = paths.map((path, index) => {
  const href = `/${paths.slice(0, index + 1).join('/')}`;
  // Replace hyphens/underscores with spaces and capitalize words
  const label = path
    .replace(/[-_]/g, ' ')
    .replace(/\b\w/g, (char) => char.toUpperCase());
    
  return {
    label,
    href,
  };
});
---

{breadcrumbs.length > 0 && (
  <nav aria-label="Breadcrumb" class="py-4 container mx-auto px-4">
    <ol class="flex items-center gap-2 text-sm text-gray-500">
      <li>
        <a href="/" class="hover:text-brand-primary transition flex items-center gap-1" aria-label="Volver al inicio">
          <Icon name="House" size={16} />
        </a>
      </li>
      {breadcrumbs.map((crumb, index) => {
        const isLast = index === breadcrumbs.length - 1;
        
        return (
          <li class="flex items-center gap-2">
            <Icon name="ChevronRight" size={14} className="text-gray-400" />
            {isLast ? (
              <span class="font-bold text-brand-dark" aria-current="page">
                {crumb.label}
              </span>
            ) : (
              <a href={crumb.href} class="hover:text-brand-primary transition">
                {crumb.label}
              </a>
            )}
          </li>
        );
      })}
    </ol>
  </nav>
)}
