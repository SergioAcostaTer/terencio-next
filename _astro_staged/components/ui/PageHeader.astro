---
import defaultBg from "../../assets/supermercados-terencio.jpg";

interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
  badgeClass?: string;
  backgroundImage?: string;
  gradientClass?: string;
  bgClass?: string;
  animate?: boolean;
}

const { title, subtitle, badge, badgeClass, backgroundImage, gradientClass, bgClass, animate = true } = Astro.props;
const bgImage = backgroundImage || defaultBg.src;
---

<section class={`relative ${bgClass || 'bg-green-900'} text-white py-8 md:py-12 overflow-hidden group`}>
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <img 
      src={bgImage} 
      alt="" 
      class={`w-full h-full object-cover opacity-30 mix-blend-overlay transition-transform duration-[2s] group-hover:scale-105 ${animate ? 'animate-fade-in' : ''}`} 
    />
    <div class={`absolute inset-0 ${gradientClass || 'bg-gradient-to-b from-green-900/90 via-green-900/60 to-green-900/90'}`}></div>
  </div>
  
  <div class="container mx-auto px-4 relative z-10 text-center">
    {badge && (
       <span class={`inline-block py-1 px-3 rounded-full text-xs font-bold uppercase tracking-wider mb-4 ${badgeClass || 'bg-green-800/80 border border-green-400 text-green-100'} ${animate ? 'animate-fade-in-up' : ''}`}>
          {badge}
       </span>
    )}

    <h1 class={`text-3xl md:text-4xl lg:text-5xl font-extrabold mb-4 tracking-tight text-white drop-shadow-sm leading-tight ${animate ? 'animate-fade-in-up delay-100' : ''}`} set:html={title} />

    {subtitle && (
      <p class={`text-lg md:text-xl text-green-100 max-w-2xl mx-auto font-medium leading-relaxed mb-6 ${animate ? 'animate-fade-in-up delay-200' : ''}`}>
        {subtitle}
      </p>
    )}

    {/* Slot for buttons or extra content - Standardized Layout */}
    <div class={`mt-6 empty:mt-0 flex flex-col sm:flex-row gap-4 justify-center items-center ${animate ? 'animate-fade-in-up delay-300' : ''}`}>
      <slot />
    </div>
  </div>
</section>

<style>
  .delay-100 { animation-delay: 100ms; }
  .delay-200 { animation-delay: 200ms; }
  .delay-300 { animation-delay: 300ms; }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .animate-fade-in {
    animation: fadeIn 1.5s ease-out forwards;
  }
</style>
