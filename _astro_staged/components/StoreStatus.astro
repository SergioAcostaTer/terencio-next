---
---

<div id="store-status-wrapper" class="block w-full transition-colors duration-500 bg-green-700 border-b border-gray-200 cursor-pointer hover:bg-green-800">
  <div class="container mx-auto px-4 lg:px-6 flex justify-center items-center py-2">
    <div class="flex items-center gap-2 text-sm font-medium text-white group">
      <span id="status-icon" class="material-icons-outlined text-base">check_circle</span>
      <span id="status-text" class="uppercase tracking-wide">ABIERTO</span>
      <span class="material-icons-outlined text-white/70 group-hover:text-white transition-colors text-sm ml-1">info</span>
    </div>
  </div>
</div>

<!-- Hours Modal -->
<dialog id="hours-modal" class="p-0 rounded-2xl shadow-2xl backdrop:bg-black/50 border-none w-[90%] max-w-md open:animate-fade-in m-auto">
    <div class="bg-white p-6">
        <div class="flex justify-between items-center mb-6 border-b border-gray-100 pb-4">
            <h3 class="text-xl font-bold text-gray-900 flex items-center gap-2">
                <span class="material-icons-outlined text-green-600">store</span> Horario Detallado
            </h3>
            <button id="close-modal" class="text-gray-400 hover:text-gray-600 transition p-2 hover:bg-gray-100 rounded-full">
                <span class="material-icons-outlined">close</span>
            </button>
        </div>
        
        <div class="space-y-4">
            <!-- Current Status in Modal -->
            <div id="modal-status-banner" class="bg-green-50 text-green-800 p-4 rounded-xl flex items-center gap-3 font-bold border border-green-200">
                <span class="material-icons-outlined">check_circle</span>
                <span id="modal-status-text">Abierto ahora</span>
            </div>

            <div class="space-y-2 text-sm">
                <div class="flex justify-between py-2 border-b border-gray-50">
                    <span class="text-gray-500">Lunes - Sábado</span>
                    <span class="font-bold text-gray-900">08:00 - 21:00</span>
                </div>
                <div class="flex justify-between py-2 border-b border-gray-50 bg-yellow-50/50 -mx-2 px-2 rounded">
                    <span class="text-gray-600 font-medium">Domingos y Festivos</span>
                    <span class="font-bold text-gray-900">08:30 - 20:30</span>
                </div>
            </div>

            <p class="text-xs text-center text-gray-400 mt-4">
                Horario continuo. No cerramos a mediodía.<br>
                Ubicación: Ctra. La Esperanza 22, La Laguna.
            </p>
        </div>
    </div>
</dialog>

<script>
  function updateStoreStatus() {
     // Canary Islands Timezone
     const now = new Date();
     const formatOptions: Intl.DateTimeFormatOptions = {
       timeZone: 'Atlantic/Canary',
       hour: 'numeric',
       minute: 'numeric',
       second: 'numeric',
       hour12: false,
       weekday: 'short',
       month: 'numeric',
       day: 'numeric'
     };
     const formatter = new Intl.DateTimeFormat('en-US', formatOptions);
     
     // Parse parts
     const parts = formatter.formatToParts(now);
     const getPart = (type: string) => parts.find(p => p.type === type)?.value;
     
     const day = parseInt(getPart('day') || '0');
     const month = parseInt(getPart('month') || '0');
     const hour = parseInt(getPart('hour') || '0');
     const minute = parseInt(getPart('minute') || '0');
     const weekday = getPart('weekday'); // Mon, Tue, Wed, ...

     // Special Holidays: 25/12, 1/1, 6/1
     const isHoliday = (month === 12 && day === 25) || (month === 1 && day === 1) || (month === 1 && day === 6);

     const statusWrapper = document.getElementById('store-status-wrapper');
     const statusText = document.getElementById('status-text');
     const statusIcon = document.getElementById('status-icon');
     const modalStatusText = document.getElementById('modal-status-text');
     const modalStatusBanner = document.getElementById('modal-status-banner');

     if (!statusWrapper || !statusText || !statusIcon) return;

     let isOpen = false;
     let message = "";
     
     const currentTime = hour * 60 + minute;
     const isSunday = weekday === 'Sun';
     
     // Opening Times (in minutes)
     const openTime = isSunday ? 8 * 60 + 30 : 8 * 60; // 8:30 or 08:00
     const closeTime = isSunday ? 20 * 60 + 30 : 21 * 60; // 20:30 or 21:00

     if (isHoliday) {
        isOpen = false;
        // Simple logic for holiday: Assume opens next non-holiday day at 8:00 (simplification)
        message = "CERRADO POR FESTIVO"; 
     } else {
        if (currentTime >= openTime && currentTime < closeTime) {
           isOpen = true;
           // Calculate closing string
           const closeHour = Math.floor(closeTime / 60);
           const closeMin = closeTime % 60;
           const closeString = `${closeHour}:${closeMin.toString().padStart(2, '0')}`;
           message = `ABIERTO AHORA - CERRAMOS A LAS ${closeString}`;
        } else {
           isOpen = false;
           // Determine when it opens next
           if (currentTime < openTime) {
              // Opens later today
              const openHour = Math.floor(openTime / 60);
              const openMin = openTime % 60;
              const openString = `${openHour}:${openMin.toString().padStart(2, '0')}`;
              message = `CERRADO - ABRIMOS HOY A LAS ${openString}`;
           } else {
              // Opens tomorrow (or next open day)
              // Logic check for tomorrow
              const nextIsSunday = (weekday === 'Sat');
              // If today is Sat, tomorrow is Sun (opens 8:30). Else opens 8:00.
              // Note: This logic is simple and assumes tomorrow is not a holiday.
              
              const nextOpenTime = nextIsSunday ? "08:30" : "08:00";
              const dayLabel = "MAÑANA"; 
              message = `CERRADO - ABRIMOS ${dayLabel} A LAS ${nextOpenTime}`;
           }
        }
     }

     if (isOpen) {
        statusWrapper.classList.remove('bg-red-700', 'bg-gray-100');
        statusWrapper.classList.add('bg-green-700');
        statusIcon.textContent = "check_circle";
        if(modalStatusBanner) {
            modalStatusBanner.classList.remove('bg-red-50', 'text-red-800', 'border-red-200');
            modalStatusBanner.classList.add('bg-green-50', 'text-green-800', 'border-green-200');
        }
     } else {
        statusWrapper.classList.remove('bg-green-700', 'bg-gray-100');
        statusWrapper.classList.add('bg-red-700');
        statusIcon.textContent = "schedule";
        if(modalStatusBanner) {
            modalStatusBanner.classList.remove('bg-green-50', 'text-green-800', 'border-green-200');
            modalStatusBanner.classList.add('bg-red-50', 'text-red-800', 'border-red-200');
        }
     }
     statusText.textContent = message;
     if(modalStatusText) modalStatusText.textContent = message;
  }

  // Modal Logic
  const statusWrapper = document.getElementById('store-status-wrapper');
  const modal = document.getElementById('hours-modal') as HTMLDialogElement;
  const closeModal = document.getElementById('close-modal');

  if (statusWrapper && modal && closeModal) {
      statusWrapper.addEventListener('click', () => {
          modal.showModal();
      });

      closeModal.addEventListener('click', () => {
          modal.close();
      });

      modal.addEventListener('click', (e) => {
          const dialogDimensions = modal.getBoundingClientRect();
          if (
              e.clientX < dialogDimensions.left ||
              e.clientX > dialogDimensions.right ||
              e.clientY < dialogDimensions.top ||
              e.clientY > dialogDimensions.bottom
          ) {
              modal.close();
          }
      });
  }

  // Run on load and update every second for instant accuracy
  updateStoreStatus();
  setInterval(updateStoreStatus, 1000);
</script>
