---
interface Props {
  title?: string;
  className?: string;
  heightClass?: string;
}

const { 
  title = "Mapa de ubicación Terencio Cash Market",
  className = "",
  heightClass = "h-[400px] md:h-[500px]"
} = Astro.props;
---
<section class={`w-full bg-gray-100 rounded-lg overflow-hidden shadow-md relative ${className} ${heightClass}`} id="map-container">
    <iframe 
      src="https://maps.google.com/maps?q=Carr.+de+la+Esperanza,+22,+38206+La+Laguna&t=&z=15&ie=UTF8&iwloc=&output=embed"
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title={title}
      class="w-full h-full min-h-[400px]"
    ></iframe>
</section>

